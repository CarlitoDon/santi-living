{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "PROXY_API_SECRET",
    "SANTI_PROXY_URL",
    "SYNC_ERP_API_URL",
    "SYNC_ERP_API_SECRET",
    "MIDTRANS_CLIENT_KEY",
    "MIDTRANS_SERVER_KEY",
    "MIDTRANS_IS_PRODUCTION",
    "ERP_SYNC_SERVICE_URL",
    "BOT_SECRET",
    "VERCEL_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {}
  }
}
