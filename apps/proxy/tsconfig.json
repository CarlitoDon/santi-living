{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "declaration": true,
    "paths": {
      "@/*": ["src/*"],
      "@sync-erp/shared/trpc": ["node_modules/@sync-erp/shared/dist/trpc"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
