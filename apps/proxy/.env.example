# ERP Sync Service Environment
# =============================
# Backend service untuk sync rental orders dengan sync-erp API
# Port 3002 by default

# Server Configuration
PORT=3002
NODE_ENV=development
CORS_ORIGINS=http://localhost:4321,http://localhost:3000

# Santi Living Company (CRITICAL)
# UUID dari company di sync-erp database yang merepresentasikan santi-living
SANTI_LIVING_COMPANY_ID=demo-company-rental

# Frontend Configuration
# Public base URL untuk order tracking links
PUBLIC_BASE_URL=http://localhost:4321
# Admin WhatsApp untuk notifikasi
ADMIN_WHATSAPP=6281234567890

# Sync-ERP API Connection (CRITICAL)
# URL ke sync-erp tRPC API backend
SYNC_ERP_API_URL=http://localhost:3001/api/trpc
# Shared secret untuk authenticate dengan sync-erp API
# WAJIB SAMA dengan BOT_SECRET di sync-erp
BOT_SECRET=dev_bot_secret_key_2026

# WhatsApp Bot Service Integration (Optional)
# Jika ingin kirim notifikasi via WhatsApp
BOT_SERVICE_URL=http://localhost:3000
BOT_SERVICE_API_KEY=your_bot_api_secret_here

# Local API Authentication (CRITICAL)
# Secret key untuk santi-living's own API endpoints
# Frontend harus send ini di Authorization header untuk /api/* calls
API_KEY=erp_sync_secret_2026

# Midtrans Payment Gateway
# Dapatkan dari https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx
MIDTRANS_IS_PRODUCTION=false

# Legacy (Optional - deprecated)
# Fallback untuk backward compatibility
SYNC_ERP_API_KEY=dev_bot_secret_key_2026
