# ERP Sync Service Production Environment
PORT="8080"
NODE_ENV="production"

# sync-erp API Connection (CRITICAL)
SYNC_ERP_API_URL="https://your-erp-api-service.up.railway.app/api/trpc"
BOT_SECRET="your_bot_secret"

# Local API Authentication (for frontend)
API_KEY="your_api_key"

# Company Configuration
SANTI_LIVING_COMPANY_ID="demo-company-rental"

# Public Configuration
PUBLIC_BASE_URL="https://santiliving.com"
ADMIN_PHONE="628xxxxxxxxxx"

# Midtrans Configuration (Production)
MIDTRANS_SERVER_KEY="your_midtrans_server_key"
MIDTRANS_CLIENT_KEY="your_midtrans_client_key"
MIDTRANS_IS_PRODUCTION="true"

# Bot Service Connection (Fix for WA Notify)
BOT_SERVICE_URL="https://your-bot-service.up.railway.app"
BOT_SERVICE_API_KEY="your_bot_service_api_key"
