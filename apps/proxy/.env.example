# Example Environment for Proxy
# Copy this file to .env, .env.staging, or .env.production
NODE_ENV=development
PORT=8080

# ========================================
# sync-erp Service Connections
# ========================================

# sync-erp API
SYNC_ERP_API_URL=https://your-api-service.up.railway.app/api/trpc
SYNC_ERP_API_SECRET=your_sync_erp_api_secret

# sync-erp Bot
SYNC_ERP_BOT_URL=https://your-bot-service.up.railway.app
SYNC_ERP_BOT_SECRET=your_sync_erp_bot_secret

# ========================================
# Proxy Self-Authentication
# ========================================

# Auth for Proxy (frontend calls with this)
PROXY_API_SECRET=your_proxy_api_secret

# ========================================
# Business Configuration
# ========================================

SANTI_LIVING_COMPANY_ID=demo-company-rental
PUBLIC_BASE_URL=https://your-domain.com
ADMIN_WHATSAPP_NUMBER=62xxxxxxxxxxx

# ========================================
# CORS
# ========================================

CORS_ALLOWED_ORIGINS=http://localhost:4321,https://your-domain.com

# ========================================
# Midtrans
# ========================================

MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
