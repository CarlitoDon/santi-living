{
  "name": "@santi-living/proxy",
  "version": "1.0.0",
  "description": "Bridge service between santi-living and sync-erp",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "prebuild": "npm run check-sync",
    "start": "node dist/index.js",
    "check-sync": "ts-node scripts/check-sync.ts",
    "predev": "npm run check-sync && (npx kill-port 3002 --silent || true)",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "sync-bundles": "ts-node src/scripts/sync-bundles.ts"
  },
  "dependencies": {
    "@trpc/client": "^11.5.0",
    "@trpc/server": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "midtrans-client": "^1.4.3",
    "superjson": "^1.13.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/midtrans-client": "^1.4.0",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
