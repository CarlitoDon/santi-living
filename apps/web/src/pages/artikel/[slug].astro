---
import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import StickyWhatsApp from "@/components/StickyWhatsApp.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Format date
const date = post.data.pubDate.toLocaleDateString("id-ID", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// JSON-LD Schema for Article
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "author": {
    "@type": "Person",
    "name": post.data.author
  },
  "datePublished": post.data.pubDate.toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Santi Mebel Jogja",
    "logo": {
      "@type": "ImageObject",
      "url": "https://santiliving.com/logo-primary.svg"
    }
  }
};
---

<MainLayout
  title={`${post.data.title} | Santi Mebel Blog`}
  description={post.data.description}
>
  <Header />
  <Sidebar />

  <main class="article-detail" style="padding-top: 70px;">
    <article class="article-container">
      <header class="article-header">
        <div class="article-meta">
          <time datetime={post.data.pubDate.toISOString()}>{date}</time>
          <span class="meta-separator">•</span>
          <span class="article-author">Oleh {post.data.author}</span>
        </div>
        
        <h1 class="article-title">{post.data.title}</h1>
        
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map(tag => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="article-content prose">
        <Content />
      </div>
      
      <footer class="article-footer">
        <div class="share-box">
          <p>Butuh kasur untuk disewa?</p>
          <a href="/produk" class="btn btn-primary">Lihat Katalog Kasur</a>
        </div>
      </footer>
    </article>
  </main>

  <StickyWhatsApp />
  
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</MainLayout>

<style>
  .article-detail {
    min-height: calc(100vh - 70px);
    background: var(--color-gray-50);
    padding-bottom: var(--space-16);
  }

  .article-container {
    max-width: 800px;
    margin: 0 auto;
    background: white;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    min-height: 100vh;
  }

  .article-header {
    padding: var(--space-8) var(--space-5) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .meta-separator {
    color: var(--color-gray-300);
  }

  .article-title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    line-height: 1.3;
    margin-bottom: var(--space-4);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-size: var(--font-size-sm);
    color: var(--color-primary);
    background: #eef2ff;
    padding: 2px var(--space-3);
    border-radius: var(--radius-full);
  }

  /* Markdown Content Styling */
  .article-content {
    padding: var(--space-8) var(--space-5);
  }

  .article-content :global(h2) {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin: var(--space-8) 0 var(--space-4);
  }

  .article-content :global(h3) {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-800);
    margin: var(--space-6) 0 var(--space-3);
  }

  .article-content :global(p) {
    font-size: var(--font-size-base);
    line-height: 1.8;
    color: var(--color-gray-700);
    margin-bottom: var(--space-4);
  }

  .article-content :global(ul), .article-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
    color: var(--color-gray-700);
    line-height: 1.8;
  }

  .article-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .article-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .article-content :global(strong) {
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
  }

  /* Footer */
  .article-footer {
    padding: var(--space-8) var(--space-5);
    border-top: 1px solid var(--color-gray-100);
    background: var(--color-gray-50);
  }

  .share-box {
    background: white;
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .share-box p {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-4);
    color: var(--color-gray-900);
  }

  @media (min-width: 640px) {
    .article-container {
      margin-top: var(--space-8);
      border-radius: var(--radius-lg);
      min-height: auto;
    }
    
    .article-header {
      padding: var(--space-10) var(--space-10) var(--space-8);
    }
    
    .article-title {
      font-size: var(--font-size-3xl);
    }
    
    .article-content {
      padding: var(--space-10);
    }
    
    .article-footer {
      padding: var(--space-10);
    }
  }
</style>
