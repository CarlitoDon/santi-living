---
export const prerender = true;

import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import BlogCard from "@/components/BlogCard.astro";

// Get all published blog posts, sorted by date (newest first)
const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.pubDate <= new Date() : true;
});

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<MainLayout
  title="Artikel & Tips Seputar Sewa Kasur Jogja | Santi Mebel"
  description="Kumpulan artikel, tips, dan panduan lengkap seputar sewa kasur, memilih kasur untuk kos, dan kebutuhan penginapan di Yogyakarta."
>
  <Header />
  <Sidebar />

  <main class="blog-archive" style="padding-top: 70px;">
    <!-- Hero Header -->
    <header class="blog-header">
      <div class="container">
        <h1 class="blog-title">Tips & Artikel</h1>
        <p class="blog-subtitle">
          Panduan lengkap seputar kasur, kos, dan living di Jogja.
        </p>
      </div>
    </header>

    <!-- Post Grid -->
    <section class="blog-content">
      <div class="container">
        {posts.length === 0 ? (
          <div class="empty-state">
            <p>Belum ada artikel yang dipublikasikan.</p>
          </div>
        ) : (
          <div class="post-grid">
            {posts.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .blog-archive {
    min-height: calc(100vh - 70px);
    background: var(--color-gray-50);
  }

  .blog-header {
    background: white;
    padding: var(--space-10) 0;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-title {
    font-size: var(--font-size-2xl);
    color: var(--color-gray-900);
    margin-bottom: var(--space-2);
  }

  .blog-subtitle {
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-content {
    padding: var(--space-10) 0 var(--space-16);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
    color: var(--color-text-secondary);
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .blog-title {
      font-size: var(--font-size-3xl);
    }
  }

  @media (min-width: 768px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .post-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
