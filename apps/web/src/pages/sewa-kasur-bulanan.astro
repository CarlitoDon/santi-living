165|          <a
166|            href={`https://wa.me/${config.whatsappNumber}?text=Halo%20Santi%20Living,%20saya%20mau%20sewa%20kasur%20bulanan%20untuk%20[durasi]%20bulan`}
167|            class="btn btn-outline btn-lg bulanan-cta-wa"
168|            target="_blank"
169|            rel="noopener"
170|            data-wa-source="bulanan_page"
171|          >
172|            💬 Chat WhatsApp
173|          </a>
174|        </div>
175|      </div>
176|    </section>
