---
export const prerender = true;

import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import StickyWhatsApp from "@/components/StickyWhatsApp.astro";
import config from "@/data/config.json";
---

<MainLayout
  title="Sewa Kasur Bulanan Jogja | Hemat Mulai Rp750rb/Bulan - Santi Living"
  description="Sewa kasur bulanan di Jogja mulai Rp750.000/bulan. Cocok untuk kos, kontrakan, atau mahasiswa. Kasur bersih, antar jemput gratis, tanpa deposit besar. Diskon 10-15% sewa banyak."
>
  <Header />
  <Sidebar />

  <main class="bulanan-page" style="padding-top: 70px;">
    <!-- Hero -->
    <section class="bulanan-hero">
      <div class="container">
        <h1 class="bulanan-hero-title">Sewa Kasur Bulanan Jogja</h1>
        <p class="bulanan-hero-subtitle">
          Solusi hemat untuk kos, kontrakan, atau mahasiswa yang butuh kasur tanpa beli
        </p>
        <div class="bulanan-hero-price">Mulai Rp750.000/bulan</div>
      </div>
    </section>

    <!-- Kenapa Sewa Bulanan -->
    <section class="bulanan-section">
      <div class="container">
        <h2 class="bulanan-section-title">Kenapa Pilih Sewa Kasur Bulanan?</h2>
        <div class="benefit-grid">
          <div class="benefit-card">
            <div class="benefit-icon">💸</div>
            <h3>Hemat vs Beli Baru</h3>
            <p>Kasur baru mulai Rp1-3 juta. Sewa bulanan cuma Rp750rb — hemat sampai 75% untuk kebutuhan sementara!</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">🎓</div>
            <h3>Cocok untuk Mahasiswa</h3>
            <p>Baru pindah kos atau kontrakan? Sewa dulu, nanti kalau sudah settle baru beli. Tanpa ribet pindahan kasur.</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">🧹</div>
            <h3>Kasur Selalu Bersih</h3>
            <p>Setiap kasur dicuci profesional sebelum diantar. Bersih, wangi, dan dibungkus plastik steril.</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">📦</div>
            <h3>Bebas Repot</h3>
            <p>Selesai sewa? Kami jemput. Tidak perlu mikir mau diapakan kasurnya setelah kontrak habis.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Harga Bulanan -->
    <section class="bulanan-section bulanan-section-alt">
      <div class="container">
        <h2 class="bulanan-section-title">Harga Sewa Kasur Bulanan</h2>
        <p class="bulanan-section-desc">Semua harga sudah termasuk kasur busa berkualitas</p>

        <div class="price-cards">
          <div class="price-card">
            <div class="price-card-header">Single Standard</div>
            <div class="price-card-size">90 × 200 cm</div>
            <div class="price-card-price">Rp 750.000<span>/bulan</span></div>
            <div class="price-card-daily">≈ Rp 25.000/hari</div>
            <div class="price-card-note">1 orang • kasur busa saja</div>
          </div>
          <div class="price-card price-card-popular">
            <div class="price-card-badge">Best Value</div>
            <div class="price-card-header">Paket Lengkap Single</div>
            <div class="price-card-size">Kasur + Sprei + Bantal + Selimut</div>
            <div class="price-card-price">Rp 1.050.000<span>/bulan</span></div>
            <div class="price-card-daily">≈ Rp 35.000/hari</div>
            <div class="price-card-note">1 orang • siap pakai langsung</div>
          </div>
          <div class="price-card">
            <div class="price-card-header">Double</div>
            <div class="price-card-size">120 × 200 cm</div>
            <div class="price-card-price">Rp 1.050.000<span>/bulan</span></div>
            <div class="price-card-daily">≈ Rp 35.000/hari</div>
            <div class="price-card-note">1-2 orang • kasur busa saja</div>
          </div>
        </div>

        <p class="bulanan-section-note">
          <a href="/harga-sewa-kasur">Lihat daftar harga lengkap semua ukuran →</a>
        </p>
      </div>
    </section>

    <!-- Siapa yang Sewa Bulanan -->
    <section class="bulanan-section">
      <div class="container">
        <h2 class="bulanan-section-title">Siapa yang Biasanya Sewa Kasur Bulanan?</h2>
        <div class="audience-grid">
          <div class="audience-item">
            <span class="audience-icon">🎓</span>
            <div>
              <strong>Mahasiswa Baru</strong>
              <p>Baru pindah kos di Jogja, belum sempat beli kasur. Sewa dulu 1-3 bulan sambil settle.</p>
            </div>
          </div>
          <div class="audience-item">
            <span class="audience-icon">🏠</span>
            <div>
              <strong>Penghuni Kontrakan Sementara</strong>
              <p>Kontrak 3-6 bulan? Beli kasur terlalu mahal, sewa jauh lebih hemat dan praktis.</p>
            </div>
          </div>
          <div class="audience-item">
            <span class="audience-icon">💼</span>
            <div>
              <strong>Pekerja Project</strong>
              <p>Karyawan yang ditugaskan ke Jogja sementara. Butuh kasur tanpa harus beli furniture.</p>
            </div>
          </div>
          <div class="audience-item">
            <span class="audience-icon">🏢</span>
            <div>
              <strong>Pemilik Kos/Penginapan</strong>
              <p>Perlu kasur tambahan untuk kamar baru? Sewa banyak unit, dapat diskon 10-15%!</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bulanan-section bulanan-section-alt">
      <div class="container">
        <h2 class="bulanan-section-title">Pertanyaan tentang Sewa Bulanan</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary class="faq-question">Apakah sewa bulanan lebih murah dari harian?</summary>
            <p class="faq-answer">Ya! Harga sewa bulanan dihitung dari tarif harian × 30 hari tanpa markup. Dibanding beli kasur baru (Rp1-3 juta), sewa bulanan jauh lebih hemat untuk kebutuhan sementara.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">Bisa perpanjang sewa kasur bulanan?</summary>
            <p class="faq-answer">Tentu! Cukup hubungi kami via WhatsApp sebelum masa sewa habis. Perpanjangan tanpa biaya administrasi tambahan.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">Apakah ada deposit atau jaminan?</summary>
            <p class="faq-answer">Tidak ada deposit besar. Cukup bayar biaya sewa + ongkir di awal. Kami percaya pada pelanggan kami.</p>
          </details>
          <details class="faq-item">
            <summary class="faq-question">Bagaimana kalau kasur rusak saat disewa?</summary>
            <p class="faq-answer">Kerusakan normal akibat pemakaian wajar tidak dikenakan biaya. Untuk kerusakan besar (robek, terkena air berlebih), akan ada biaya penggantian yang wajar sesuai kondisi.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bulanan-cta">
      <div class="container">
        <h2 class="bulanan-cta-title">Butuh kasur untuk sewa bulanan?</h2>
        <p class="bulanan-cta-desc">Hubungi kami — bisa antar hari ini!</p>
        <div class="bulanan-cta-buttons">
          <a href="/#calculator" class="btn btn-primary btn-lg">Hitung Biaya Sewa</a>
          <a
            href={`https://wa.me/${config.whatsappNumber}?text=Halo%20Santi%20Living,%20saya%20mau%20sewa%20kasur%20bulanan%20untuk%20[durasi]%20bulan`}
            class="btn btn-outline btn-lg bulanan-cta-wa"
            target="_blank"
            rel="noopener"
            data-wa-source="bulanan_page"
          >
            💬 Chat WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ Schema -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Apakah sewa kasur bulanan lebih murah dari harian?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ya! Harga sewa bulanan dihitung dari tarif harian × 30 hari tanpa markup. Dibanding beli kasur baru (Rp1-3 juta), sewa bulanan jauh lebih hemat untuk kebutuhan sementara."
            }
          },
          {
            "@type": "Question",
            "name": "Bisa perpanjang sewa kasur bulanan?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Tentu! Cukup hubungi kami via WhatsApp sebelum masa sewa habis. Perpanjangan tanpa biaya administrasi tambahan."
            }
          },
          {
            "@type": "Question",
            "name": "Apakah ada deposit atau jaminan untuk sewa kasur?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Tidak ada deposit besar. Cukup bayar biaya sewa + ongkir di awal."
            }
          }
        ]
      })}
    />
  </main>

  <StickyWhatsApp />
</MainLayout>

<style>
  .bulanan-hero {
    background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);
    padding: var(--space-10) 0 var(--space-8);
    text-align: center;
    color: white;
  }

  .bulanan-hero-title {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-2);
    color: white;
  }

  .bulanan-hero-subtitle {
    font-size: var(--font-size-base);
    opacity: 0.9;
    margin-bottom: var(--space-3);
  }

  .bulanan-hero-price {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.4);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    font-weight: var(--font-weight-bold);
  }

  .bulanan-section {
    padding: var(--space-10) 0;
  }

  .bulanan-section-alt {
    background: var(--color-surface);
  }

  .bulanan-section-title {
    text-align: center;
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-2);
  }

  .bulanan-section-desc {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .bulanan-section-note {
    text-align: center;
    margin-top: var(--space-4);
    font-size: var(--font-size-sm);
  }

  .bulanan-section-note a {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
  }

  /* Benefits */
  .benefit-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    max-width: 640px;
    margin: var(--space-6) auto 0;
  }

  .benefit-card {
    text-align: center;
    padding: var(--space-5);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .benefit-icon {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .benefit-card h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-1);
  }

  .benefit-card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Price Cards */
  .price-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    max-width: 720px;
    margin: 0 auto;
  }

  .price-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    text-align: center;
    position: relative;
  }

  .price-card-popular {
    border-color: #0891b2;
    box-shadow: 0 4px 12px rgba(8, 145, 178, 0.15);
  }

  .price-card-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: #0891b2;
    color: white;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    padding: 2px var(--space-3);
    border-radius: var(--radius-full);
  }

  .price-card-header {
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-base);
    margin-bottom: var(--space-1);
  }

  .price-card-size {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .price-card-price {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: #0891b2;
  }

  .price-card-price span {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-normal);
    color: var(--color-text-secondary);
  }

  .price-card-daily {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    margin-top: var(--space-1);
  }

  .price-card-note {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    margin-top: var(--space-2);
  }

  /* Audience */
  .audience-grid {
    max-width: 560px;
    margin: var(--space-6) auto 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .audience-item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .audience-icon {
    flex-shrink: 0;
    font-size: 1.5rem;
    margin-top: 2px;
  }

  .audience-item strong {
    display: block;
    margin-bottom: 2px;
  }

  .audience-item p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* FAQ */
  .faq-list {
    max-width: 640px;
    margin: var(--space-6) auto 0;
  }

  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3);
    background: white;
    overflow: hidden;
  }

  .faq-question {
    padding: var(--space-4);
    cursor: pointer;
    font-weight: var(--font-weight-semibold);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-question::after {
    content: "+";
    font-size: var(--font-size-xl);
    color: #0891b2;
    transition: transform 0.2s;
  }

  .faq-item[open] .faq-question::after {
    content: "−";
  }

  .faq-answer {
    padding: 0 var(--space-4) var(--space-4);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* CTA */
  .bulanan-cta {
    background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);
    padding: var(--space-10) 0;
    text-align: center;
    color: white;
  }

  .bulanan-cta-title {
    font-size: var(--font-size-2xl);
    color: white;
    margin-bottom: var(--space-2);
  }

  .bulanan-cta-desc {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-6);
  }

  .bulanan-cta-buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .bulanan-cta-buttons .btn-primary {
    background: white;
    color: #0891b2;
    max-width: 280px;
    width: 100%;
  }

  .bulanan-cta-wa {
    max-width: 280px;
    width: 100%;
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
  }

  .bulanan-cta-wa:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: white;
  }

  @media (min-width: 640px) {
    .bulanan-hero-title {
      font-size: var(--font-size-3xl);
    }
    .bulanan-cta-buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  @media (max-width: 639px) {
    .price-cards {
      grid-template-columns: 1fr;
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>
