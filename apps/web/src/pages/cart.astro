---
export const prerender = true;

import MainLayout from "@/layouts/MainLayout.astro";
import Calculator from "@/components/CalculatorWrapper.astro";
---

<MainLayout title="Keranjang - Sewa Kasur Jogja">
  <main class="cart-page">
    <div class="container">
      <div class="cart-header">
        <a href="/checkout" class="btn-back"> ← Kembali ke Checkout </a>
        <h1 class="cart-title">Edit Pesanan</h1>
      </div>

      <!-- isEditMode triggers pre-fill and button text change -->
      <Calculator />
    </div>
  </main>

  <script>
    // Signal to React Calculator that we're in edit mode
    // This is picked up by Calculator.tsx to pre-fill and change button text
    (
      window as Window & { __CALCULATOR_EDIT_MODE__?: boolean }
    ).__CALCULATOR_EDIT_MODE__ = true;
  </script>
</MainLayout>

<style>
  .cart-page {
    min-height: 100vh;
    padding: var(--space-6) 0;
    background: var(--color-background);
  }

  .cart-header {
    max-width: 900px;
    margin: 0 auto var(--space-4);
    padding: 0 var(--space-4);
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color 0.2s;
    min-height: 44px;
  }

  .btn-back:hover {
    color: var(--color-primary);
  }

  .cart-title {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-top: var(--space-2);
  }
</style>
