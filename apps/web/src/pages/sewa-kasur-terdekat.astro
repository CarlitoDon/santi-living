1|---
2|export const prerender = true;
3|
4|import MainLayout from "@/layouts/MainLayout.astro";
5|import Header from "@/components/Header.astro";
6|import Sidebar from "@/components/Sidebar.astro";
7|import StickyWhatsApp from "@/components/StickyWhatsApp.astro";
8|import config from "@/data/config.json";
9|---
10|
11|<MainLayout
12|  title="Sewa Kasur Terdekat di Jogja | Pengiriman 2-4 Jam - Santi Mebel"
13|  description="Cari sewa kasur terdekat di Jogja? Santi Mebel Godean siap antar kasur bersih ke lokasi kamu dalam 2-4 jam. Gratis ongkir radius 3km. Mulai Rp30rb/hari."
14|>
15|  <Header />
16|  <Sidebar />
17|
18|  <main class="terdekat-page" style="padding-top: 70px;">
19|    <!-- Hero -->
20|    <section class="terdekat-hero">
21|      <div class="container">
22|        <h1 class="terdekat-hero-title">Sewa Kasur Terdekat di Jogja</h1>
23|        <p class="terdekat-hero-subtitle">
24|          Pengiriman cepat 2-4 jam ke lokasi kamu. Kasur bersih, harga terjangkau.
25|        </p>
26|        <div class="terdekat-hero-badge">📍 Lokasi: Godean, Sleman, Yogyakarta</div>
27|      </div>
28|    </section>
29|
30|    <!-- Kenapa Kami Terdekat -->
31|    <section class="terdekat-section">
32|      <div class="container">
33|        <h2 class="terdekat-section-title">Kenapa Santi Mebel Jadi Pilihan Terdekat?</h2>
34|        <div class="advantage-grid">
35|          <div class="advantage-card">
36|            <div class="advantage-icon">🚚</div>
37|            <h3>Antar 2-4 Jam</h3>
38|            <p>Order sebelum jam 15:00, kasur sampai hari ini juga</p>
39|          </div>
40|          <div class="advantage-card">
41|            <div class="advantage-icon">🎉</div>
42|            <h3>Gratis Ongkir</h3>
43|            <p>Pengiriman GRATIS untuk radius 3 km dari toko kami di Godean</p>
44|          </div>
45|          <div class="advantage-card">
46|            <div class="advantage-icon">✨</div>
47|            <h3>Kasur Bersih & Steril</h3>
48|            <p>Dicuci profesional & dibungkus plastik setiap pengiriman</p>
49|          </div>
50|          <div class="advantage-card">
51|            <div class="advantage-icon">💰</div>
52|            <h3>Mulai Rp30rb/hari</h3>
53|            <p>Harga terjangkau + diskon 10-15% untuk sewa banyak</p>
54|          </div>
55|        </div>
56|      </div>
57|    </section>
58|
59|    <!-- Area Layanan -->
60|    <section class="terdekat-section terdekat-section-alt">
61|      <div class="container">
62|        <h2 class="terdekat-section-title">Area Pengiriman Kasur Terdekat</h2>
63|        <p class="terdekat-section-desc">Kami melayani seluruh wilayah DIY dengan ongkir terjangkau</p>
64|
65|        <div class="area-grid">
66|          <div class="area-card area-free">
67|            <div class="area-badge">GRATIS ONGKIR</div>
68|            <h3>Radius 0-3 km</h3>
69|            <p>Godean, Gamping, Moyudan</p>
70|            <div class="area-price">Rp 0</div>
71|          </div>
72|          <div class="area-card">
73|            <div class="area-badge">ZONA 1</div>
74|            <h3>Radius 3-8 km</h3>
75|            <p>Sleman, Mlati, Depok, Sedayu</p>
76|            <div class="area-price">Rp 15.000</div>
77|          </div>
78|          <div class="area-card">
79|            <div class="area-badge">ZONA 2</div>
80|            <h3>Radius 8-15 km</h3>
81|            <p>Kota Jogja, Bantul, Kalasan</p>
82|            <div class="area-price">Rp 25.000</div>
83|          </div>
84|          <div class="area-card">
85|            <div class="area-badge">ZONA 3</div>
86|            <h3>&gt; 15 km</h3>
87|            <p>Kulon Progo, Gunung Kidul, dll</p>
88|            <div class="area-price">Rp 1.500/km</div>
89|          </div>
90|        </div>
91|      </div>
92|    </section>
93|
94|    <!-- Cara Order -->
95|    <section class="terdekat-section">
96|      <div class="container">
97|        <h2 class="terdekat-section-title">Cara Sewa Kasur Terdekat</h2>
98|        <div class="steps-grid">
99|          <div class="step-card">
100|            <div class="step-number">1</div>
101|            <h3>Pilih Kasur</h3>
102|            <p>Pilih jenis & ukuran kasur di <a href="/produk">halaman produk</a> kami</p>
103|          </div>
104|          <div class="step-card">
105|            <div class="step-number">2</div>
106|            <h3>Hubungi Kami</h3>
107|            <p>Chat WhatsApp atau isi form checkout di website</p>
108|          </div>
109|          <div class="step-card">
110|            <div class="step-number">3</div>
111|            <h3>Kasur Diantar</h3>
112|            <p>Tim kami antar kasur bersih ke lokasi kamu dalam 2-4 jam</p>
113|          </div>
114|        </div>
115|      </div>
116|    </section>
117|
118|    <!-- CTA -->
119|    <section class="terdekat-cta">
120|      <div class="container">
121|        <h2 class="terdekat-cta-title">Butuh kasur terdekat sekarang?</h2>
122|        <p class="terdekat-cta-desc">Hubungi kami — bisa antar hari ini!</p>
123|        <div class="terdekat-cta-buttons">
124|          <a href="/produk" class="btn btn-primary btn-lg">Lihat Katalog Kasur</a>
125|          <a
126|            href={`https://wa.me/${config.whatsappNumber}?text=Halo%20Santi%20Mebel,%20saya%20cari%20sewa%20kasur%20terdekat%20di%20area%20[lokasi]`}
127|            class="btn btn-outline btn-lg terdekat-cta-wa"
128|            target="_blank"
129|            rel="noopener"
130|            data-wa-source="terdekat_page"
131|          >
132|            💬 Chat WhatsApp
133|          </a>
134|        </div>
135|      </div>
136|    </section>
137|
138|    <!-- LocalBusiness Schema with areaServed -->
139|    <script
140|      type="application/ld+json"
141|      is:inline
142|      set:html={JSON.stringify({
143|        "@context": "https://schema.org",
144|        "@type": "LocalBusiness",
145|        "name": "Sewa Kasur Jogja by Santi Mebel",
146|        "description": "Layanan sewa kasur terdekat di Jogja dengan pengiriman cepat 2-4 jam",
147|        "url": "https://santiliving.com/sewa-kasur-terdekat",
148|        "telephone": `+${config.whatsappNumber}`,
149|        "address": {
150|          "@type": "PostalAddress",
151|          "streetAddress": "Jl. Godean KM 10",
152|          "addressLocality": "Yogyakarta",
153|          "postalCode": "55264",
154|          "addressRegion": "DI Yogyakarta",
155|          "addressCountry": "ID"
156|        },
157|        "geo": {
158|          "@type": "GeoCoordinates",
159|          "latitude": -7.7956,
160|          "longitude": 110.3695
161|        },
162|        "areaServed": [
163|          {"@type": "City", "name": "Yogyakarta"},
164|          {"@type": "AdministrativeArea", "name": "Sleman"},
165|          {"@type": "AdministrativeArea", "name": "Bantul"},
166|          {"@type": "AdministrativeArea", "name": "Kulon Progo"},
167|          {"@type": "AdministrativeArea", "name": "Gunung Kidul"}
168|        ],
169|        "priceRange": "Rp 25.000 - Rp 65.000"
170|      })}
171|    />
172|  </main>
173|
174|  <StickyWhatsApp />
175|</MainLayout>
176|
177|<style>
178|  .terdekat-hero {
179|    background: linear-gradient(135deg, #059669 0%, #047857 100%);
180|    padding: var(--space-10) 0 var(--space-8);
181|    text-align: center;
182|    color: white;
183|  }
184|
185|  .terdekat-hero-title {
186|    font-size: var(--font-size-2xl);
187|    margin-bottom: var(--space-2);
188|    color: white;
189|  }
190|
191|  .terdekat-hero-subtitle {
192|    font-size: var(--font-size-base);
193|    opacity: 0.9;
194|    margin-bottom: var(--space-3);
195|  }
196|
197|  .terdekat-hero-badge {
198|    display: inline-block;
199|    background: rgba(255, 255, 255, 0.2);
200|    padding: var(--space-1) var(--space-4);
201|    border-radius: var(--radius-full);
202|    font-size: var(--font-size-sm);
203|  }
204|
205|  .terdekat-section {
206|    padding: var(--space-10) 0;
207|  }
208|
209|  .terdekat-section-alt {
210|    background: var(--color-surface);
211|  }
212|
213|  .terdekat-section-title {
214|    text-align: center;
215|    font-size: var(--font-size-xl);
216|    margin-bottom: var(--space-2);
217|  }
218|
