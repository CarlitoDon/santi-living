---
export const prerender = true;

import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import StickyWhatsApp from "@/components/StickyWhatsApp.astro";
import config from "@/data/config.json";
---

<MainLayout
  title="Sewa Kasur Lipat Jogja | Praktis untuk Tamu & Acara - Santi Mebel"
  description="Sewa kasur lipat di Jogja mulai Rp25rb/hari. Praktis untuk tamu menginap, acara kantor, atau kos. Kasur bersih, antar same day. Order via WhatsApp."
>
  <Header />
  <Sidebar />

  <main class="lipat-page" style="padding-top: 70px;">
    <!-- Hero -->
    <section class="lipat-hero">
      <div class="container">
        <h1 class="lipat-hero-title">Sewa Kasur Lipat Jogja</h1>
        <p class="lipat-hero-subtitle">
          Solusi praktis untuk tamu menginap, acara, atau kebutuhan mendadak
        </p>
        <div class="lipat-hero-price">Mulai Rp25.000/hari</div>
      </div>
    </section>

    <!-- Kapan Butuh Kasur Lipat -->
    <section class="lipat-section">
      <div class="container">
        <h2 class="lipat-section-title">Kapan Butuh Sewa Kasur Lipat?</h2>
        <div class="usecase-grid">
          <div class="usecase-card">
            <div class="usecase-icon">👨‍👩‍👧‍👦</div>
            <h3>Tamu Menginap</h3>
            <p>Keluarga atau teman datang berkunjung? Kasur lipat siap pakai, tinggal gelar!</p>
          </div>
          <div class="usecase-card">
            <div class="usecase-icon">🎉</div>
            <h3>Acara & Event</h3>
            <p>Arisan, pernikahan, camping — sewa banyak unit sekaligus, dapat diskon!</p>
          </div>
          <div class="usecase-card">
            <div class="usecase-icon">🏠</div>
            <h3>Kos & Kontrakan</h3>
            <p>Baru pindah kos tapi belum beli kasur? Sewa dulu, praktis dan hemat</p>
          </div>
          <div class="usecase-card">
            <div class="usecase-icon">🏢</div>
            <h3>Penginapan Kantor</h3>
            <p>Training, workshop, atau lembur menginap — kasur siap antar ke kantor</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Harga -->
    <section class="lipat-section lipat-section-alt">
      <div class="container">
        <h2 class="lipat-section-title">Harga Sewa Kasur Lipat</h2>
        <p class="lipat-section-desc">Kasur busa berkualitas, bisa dilipat dan disimpan dengan mudah</p>

        <div class="price-cards">
          <div class="price-card">
            <div class="price-card-header">Single Standard</div>
            <div class="price-card-size">90 × 200 cm</div>
            <div class="price-card-price">Rp 25.000<span>/hari</span></div>
            <div class="price-card-note">1 orang • kasur saja</div>
          </div>
          <div class="price-card price-card-popular">
            <div class="price-card-badge">Populer</div>
            <div class="price-card-header">Double</div>
            <div class="price-card-size">120 × 200 cm</div>
            <div class="price-card-price">Rp 35.000<span>/hari</span></div>
            <div class="price-card-note">1-2 orang • kasur saja</div>
          </div>
          <div class="price-card">
            <div class="price-card-header">Paket Lengkap</div>
            <div class="price-card-size">Kasur + Sprei + Bantal + Selimut</div>
            <div class="price-card-price">Rp 35.000<span>/hari</span></div>
            <div class="price-card-note">Single Standard • siap pakai</div>
          </div>
        </div>

        <p class="lipat-section-note">
          <a href="/harga-sewa-kasur">Lihat daftar harga lengkap →</a>
        </p>
      </div>
    </section>

    <!-- Keunggulan -->
    <section class="lipat-section">
      <div class="container">
        <h2 class="lipat-section-title">Keunggulan Kasur Lipat Kami</h2>
        <div class="feature-list">
          <div class="feature-item">
            <span class="feature-check">✅</span>
            <div>
              <strong>Kasur Busa Tebal 15cm</strong>
              <p>Bukan kasur tipis — kasur busa tebal yang nyaman dan empuk untuk tidur</p>
            </div>
          </div>
          <div class="feature-item">
            <span class="feature-check">✅</span>
            <div>
              <strong>Bersih & Steril</strong>
              <p>Dicuci profesional setiap selesai sewa, dibungkus plastik saat diantar</p>
            </div>
          </div>
          <div class="feature-item">
            <span class="feature-check">✅</span>
            <div>
              <strong>Antar Jemput Same Day</strong>
              <p>Order sebelum jam 15:00, kasur sampai hari ini. Gratis jemput setelah sewa selesai</p>
            </div>
          </div>
          <div class="feature-item">
            <span class="feature-check">✅</span>
            <div>
              <strong>Diskon Sewa Banyak</strong>
              <p>3-5 unit: diskon 10% • 6+ unit: diskon 15% — cocok untuk acara</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="lipat-cta">
      <div class="container">
        <h2 class="lipat-cta-title">Butuh kasur lipat sekarang?</h2>
        <p class="lipat-cta-desc">Order via WhatsApp — bisa antar hari ini!</p>
        <div class="lipat-cta-buttons">
          <a href="/produk" class="btn btn-primary btn-lg">Pilih Kasur</a>
          <a
            href={`https://wa.me/${config.whatsappNumber}?text=Halo%20Santi%20Mebel,%20saya%20mau%20sewa%20kasur%20lipat%20untuk%20[kebutuhan]`}
            class="btn btn-outline btn-lg lipat-cta-wa"
            target="_blank"
            rel="noopener"
            data-wa-source="lipat_page"
          >
            💬 Chat WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <StickyWhatsApp />
</MainLayout>

<style>
  .lipat-hero {
    background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
    padding: var(--space-10) 0 var(--space-8);
    text-align: center;
    color: white;
  }

  .lipat-hero-title {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-2);
    color: white;
  }

  .lipat-hero-subtitle {
    font-size: var(--font-size-base);
    opacity: 0.9;
    margin-bottom: var(--space-3);
  }

  .lipat-hero-price {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.4);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    font-weight: var(--font-weight-bold);
  }

  .lipat-section {
    padding: var(--space-10) 0;
  }

  .lipat-section-alt {
    background: var(--color-surface);
  }

  .lipat-section-title {
    text-align: center;
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-2);
  }

  .lipat-section-desc {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .lipat-section-note {
    text-align: center;
    margin-top: var(--space-4);
    font-size: var(--font-size-sm);
  }

  .lipat-section-note a {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
  }

  /* Use Cases */
  .usecase-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    max-width: 640px;
    margin: var(--space-6) auto 0;
  }

  .usecase-card {
    text-align: center;
    padding: var(--space-5);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .usecase-icon {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .usecase-card h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-1);
  }

  .usecase-card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Price Cards */
  .price-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    max-width: 640px;
    margin: 0 auto;
  }

  .price-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    text-align: center;
    position: relative;
  }

  .price-card-popular {
    border-color: #7c3aed;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.15);
  }

  .price-card-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: #7c3aed;
    color: white;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    padding: 2px var(--space-3);
    border-radius: var(--radius-full);
  }

  .price-card-header {
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-base);
    margin-bottom: var(--space-1);
  }

  .price-card-size {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .price-card-price {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: #7c3aed;
  }

  .price-card-price span {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-normal);
    color: var(--color-text-secondary);
  }

  .price-card-note {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    margin-top: var(--space-2);
  }

  /* Features */
  .feature-list {
    max-width: 560px;
    margin: var(--space-6) auto 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .feature-item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .feature-check {
    flex-shrink: 0;
    font-size: 1.2rem;
    margin-top: 2px;
  }

  .feature-item strong {
    display: block;
    margin-bottom: 2px;
  }

  .feature-item p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* CTA */
  .lipat-cta {
    background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
    padding: var(--space-10) 0;
    text-align: center;
    color: white;
  }

  .lipat-cta-title {
    font-size: var(--font-size-2xl);
    color: white;
    margin-bottom: var(--space-2);
  }

  .lipat-cta-desc {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-6);
  }

  .lipat-cta-buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .lipat-cta-buttons .btn-primary {
    background: white;
    color: #7c3aed;
    max-width: 280px;
    width: 100%;
  }

  .lipat-cta-wa {
    max-width: 280px;
    width: 100%;
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
  }

  .lipat-cta-wa:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: white;
  }

  @media (min-width: 640px) {
    .lipat-hero-title {
      font-size: var(--font-size-3xl);
    }
    .lipat-cta-buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  @media (max-width: 639px) {
    .price-cards {
      grid-template-columns: 1fr;
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>
