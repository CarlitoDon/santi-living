362|  }
363|
364|  .lipat-cta-buttons {
365|    display: flex;
366|    flex-direction: column;
367|    align-items: center;
368|    gap: var(--space-3);
369|  }
370|
371|  .lipat-cta-buttons .btn-primary {
372|    background: white;
373|    color: #7c3aed;
374|    max-width: 280px;
375|    width: 100%;
376|  }
377|
378|  .lipat-cta-wa {
379|    max-width: 280px;
