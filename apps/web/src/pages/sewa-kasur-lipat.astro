393|  }
394|
395|  @media (min-width: 640px) {
396|    .lipat-hero-title {
397|      font-size: var(--font-size-3xl);
398|    }
399|    .lipat-cta-buttons {
400|      flex-direction: row;
401|      justify-content: center;
402|    }
403|  }
404|
405|  @media (max-width: 639px) {
406|    .price-cards {
407|      grid-template-columns: 1fr;
408|      max-width: 300px;
409|      margin: 0 auto;
410|    }
411|  }
412|</style>
