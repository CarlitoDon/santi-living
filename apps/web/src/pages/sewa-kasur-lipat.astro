154|<style>
155|  .lipat-hero {
156|    background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
157|    padding: var(--space-10) 0 var(--space-8);
158|    text-align: center;
159|    color: white;
160|  }
161|
162|  .lipat-hero-title {
163|    font-size: var(--font-size-2xl);
164|    margin-bottom: var(--space-2);
165|    color: white;
166|  }
167|
168|  .lipat-hero-subtitle {
169|    font-size: var(--font-size-base);
170|    opacity: 0.9;
171|    margin-bottom: var(--space-3);
172|  }
173|
174|  .lipat-hero-price {
175|    display: inline-block;
176|    background: rgba(255, 255, 255, 0.2);
177|    border: 1px solid rgba(255, 255, 255, 0.4);
178|    padding: var(--space-1) var(--space-4);
179|    border-radius: var(--radius-full);
180|    font-weight: var(--font-weight-bold);
181|  }
182|
183|  .lipat-section {
184|    padding: var(--space-10) 0;
185|  }
186|
187|  .lipat-section-alt {
188|    background: var(--color-surface);
189|  }
190|
191|  .lipat-section-title {
192|    text-align: center;
193|    font-size: var(--font-size-xl);
194|    margin-bottom: var(--space-2);
195|  }
196|
197|  .lipat-section-desc {
198|    text-align: center;
199|    color: var(--color-text-secondary);
200|    margin-bottom: var(--space-6);
201|  }
202|
203|  .lipat-section-note {
204|    text-align: center;
205|    margin-top: var(--space-4);
206|    font-size: var(--font-size-sm);
207|  }
208|
209|  .lipat-section-note a {
210|    color: var(--color-primary);
211|    font-weight: var(--font-weight-semibold);
212|  }
213|
214|  /* Use Cases */
215|  .usecase-grid {
216|    display: grid;
217|    grid-template-columns: repeat(2, 1fr);
218|    gap: var(--space-4);
219|    max-width: 640px;
220|    margin: var(--space-6) auto 0;
221|  }
222|
223|  .usecase-card {
224|    text-align: center;
225|    padding: var(--space-5);
226|    background: var(--color-surface);
227|    border-radius: var(--radius-lg);
228|    border: 1px solid var(--color-border);
229|  }
230|
231|  .usecase-icon {
232|    font-size: 2rem;
233|    margin-bottom: var(--space-2);
234|  }
235|
236|  .usecase-card h3 {
237|    font-size: var(--font-size-base);
238|    margin-bottom: var(--space-1);
239|  }
240|
241|  .usecase-card p {
242|    font-size: var(--font-size-sm);
243|    color: var(--color-text-secondary);
244|    margin: 0;
245|  }
246|
247|  /* Price Cards */
248|  .price-cards {
249|    display: grid;
250|    grid-template-columns: repeat(3, 1fr);
251|    gap: var(--space-4);
252|    max-width: 640px;
253|    margin: 0 auto;
254|  }
255|
256|  .price-card {
257|    background: white;
258|    border: 1px solid var(--color-border);
259|    border-radius: var(--radius-lg);
260|    padding: var(--space-5);
261|    text-align: center;
262|    position: relative;
263|  }
264|
265|  .price-card-popular {
266|    border-color: #7c3aed;
267|    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.15);
268|  }
269|
270|  .price-card-badge {
271|    position: absolute;
272|    top: -10px;
273|    left: 50%;
274|    transform: translateX(-50%);
275|    background: #7c3aed;
276|    color: white;
277|    font-size: var(--font-size-xs);
278|    font-weight: var(--font-weight-bold);
279|    padding: 2px var(--space-3);
280|    border-radius: var(--radius-full);
281|  }
282|
283|  .price-card-header {
284|    font-weight: var(--font-weight-bold);
285|    font-size: var(--font-size-base);
286|    margin-bottom: var(--space-1);
287|  }
288|
289|  .price-card-size {
290|    font-size: var(--font-size-sm);
291|    color: var(--color-text-secondary);
292|    margin-bottom: var(--space-3);
293|  }
294|
295|  .price-card-price {
296|    font-size: var(--font-size-xl);
297|    font-weight: var(--font-weight-bold);
298|    color: #7c3aed;
299|  }
300|
301|  .price-card-price span {
302|    font-size: var(--font-size-sm);
303|    font-weight: var(--font-weight-normal);
304|    color: var(--color-text-secondary);
305|  }
306|
307|  .price-card-note {
308|    font-size: var(--font-size-xs);
309|    color: var(--color-text-secondary);
310|    margin-top: var(--space-2);
311|  }
312|
313|  /* Features */
314|  .feature-list {
315|    max-width: 560px;
316|    margin: var(--space-6) auto 0;
317|    display: flex;
318|    flex-direction: column;
319|    gap: var(--space-4);
320|  }
321|
322|  .feature-item {
323|    display: flex;
324|    gap: var(--space-3);
325|    align-items: flex-start;
326|  }
327|
328|  .feature-check {
329|    flex-shrink: 0;
330|    font-size: 1.2rem;
331|    margin-top: 2px;
332|  }
333|
334|  .feature-item strong {
335|    display: block;
336|    margin-bottom: 2px;
337|  }
338|
339|  .feature-item p {
340|    font-size: var(--font-size-sm);
341|    color: var(--color-text-secondary);
342|    margin: 0;
343|  }
344|
345|  /* CTA */
346|  .lipat-cta {
347|    background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
348|    padding: var(--space-10) 0;
349|    text-align: center;
350|    color: white;
351|  }
352|
353|  .lipat-cta-title {
354|    font-size: var(--font-size-2xl);
355|    color: white;
356|    margin-bottom: var(--space-2);
357|  }
358|
359|  .lipat-cta-desc {
360|    color: rgba(255, 255, 255, 0.85);
