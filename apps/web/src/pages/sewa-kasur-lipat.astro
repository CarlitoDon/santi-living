1|---
2|export const prerender = true;
3|
4|import MainLayout from "@/layouts/MainLayout.astro";
5|import Header from "@/components/Header.astro";
6|import Sidebar from "@/components/Sidebar.astro";
7|import StickyWhatsApp from "@/components/StickyWhatsApp.astro";
8|import config from "@/data/config.json";
9|---
10|
11|<MainLayout
12|  title="Sewa Kasur Lipat Jogja | Praktis untuk Tamu & Acara - Santi Mebel"
13|  description="Sewa kasur lipat di Jogja mulai Rp25rb/hari. Praktis untuk tamu menginap, acara kantor, atau kos. Kasur bersih, antar same day. Order via WhatsApp."
14|>
15|  <Header />
16|  <Sidebar />
17|
18|  <main class="lipat-page" style="padding-top: 70px;">
19|    <!-- Hero -->
20|    <section class="lipat-hero">
21|      <div class="container">
22|        <h1 class="lipat-hero-title">Sewa Kasur Lipat Jogja</h1>
23|        <p class="lipat-hero-subtitle">
24|          Solusi praktis untuk tamu menginap, acara, atau kebutuhan mendadak
25|        </p>
26|        <div class="lipat-hero-price">Mulai Rp30.000/hari</div>
27|      </div>
28|    </section>
29|
30|    <!-- Kapan Butuh Kasur Lipat -->
31|    <section class="lipat-section">
32|      <div class="container">
33|        <h2 class="lipat-section-title">Kapan Butuh Sewa Kasur Lipat?</h2>
34|        <div class="usecase-grid">
35|          <div class="usecase-card">
36|            <div class="usecase-icon">👨‍👩‍👧‍👦</div>
37|            <h3>Tamu Menginap</h3>
38|            <p>Keluarga atau teman datang berkunjung? Kasur lipat siap pakai, tinggal gelar!</p>
39|          </div>
40|          <div class="usecase-card">
41|            <div class="usecase-icon">🎉</div>
42|            <h3>Acara & Event</h3>
43|            <p>Arisan, pernikahan, camping — sewa banyak unit sekaligus, dapat diskon!</p>
44|          </div>
45|          <div class="usecase-card">
46|            <div class="usecase-icon">🏠</div>
47|            <h3>Kos & Kontrakan</h3>
48|            <p>Baru pindah kos tapi belum beli kasur? Sewa dulu, praktis dan hemat</p>
49|          </div>
50|          <div class="usecase-card">
51|            <div class="usecase-icon">🏢</div>
52|            <h3>Penginapan Kantor</h3>
53|            <p>Training, workshop, atau lembur menginap — kasur siap antar ke kantor</p>
54|          </div>
55|        </div>
56|      </div>
57|    </section>
58|
59|    <!-- Harga -->
60|    <section class="lipat-section lipat-section-alt">
61|      <div class="container">
62|        <h2 class="lipat-section-title">Harga Sewa Kasur Lipat</h2>
63|        <p class="lipat-section-desc">Kasur busa berkualitas, bisa dilipat dan disimpan dengan mudah</p>
64|
65|        <div class="price-cards">
66|          <div class="price-card">
67|            <div class="price-card-header">Single Standard</div>
68|            <div class="price-card-size">90 × 200 cm</div>
69|            <div class="price-card-price">Rp 30.000<span>/hari</span></div>
70|            <div class="price-card-note">1 orang • kasur saja</div>
71|          </div>
72|          <div class="price-card price-card-popular">
73|            <div class="price-card-badge">Populer</div>
74|            <div class="price-card-header">Double</div>
75|            <div class="price-card-size">120 × 200 cm</div>
76|            <div class="price-card-price">Rp 40.000<span>/hari</span></div>
77|            <div class="price-card-note">1-2 orang • kasur saja</div>
78|          </div>
79|          <div class="price-card">
80|            <div class="price-card-header">Paket Lengkap</div>
81|            <div class="price-card-size">Kasur + Sprei + Bantal + Selimut</div>
82|            <div class="price-card-price">Rp 40.000<span>/hari</span></div>
83|            <div class="price-card-note">Single Standard • siap pakai</div>
84|          </div>
85|        </div>
86|
87|        <p class="lipat-section-note">
88|          <a href="/harga-sewa-kasur">Lihat daftar harga lengkap →</a>
89|        </p>
90|      </div>
91|    </section>
92|
93|    <!-- Keunggulan -->
94|    <section class="lipat-section">
95|      <div class="container">
96|        <h2 class="lipat-section-title">Keunggulan Kasur Lipat Kami</h2>
97|        <div class="feature-list">
98|          <div class="feature-item">
99|            <span class="feature-check">✅</span>
100|            <div>
101|              <strong>Kasur Busa Tebal 15cm</strong>
102|              <p>Bukan kasur tipis — kasur busa tebal yang nyaman dan empuk untuk tidur</p>
103|            </div>
104|          </div>
105|          <div class="feature-item">
106|            <span class="feature-check">✅</span>
107|            <div>
108|              <strong>Bersih & Steril</strong>
109|              <p>Dicuci profesional setiap selesai sewa, dibungkus plastik saat diantar</p>
110|            </div>
111|          </div>
112|          <div class="feature-item">
113|            <span class="feature-check">✅</span>
114|            <div>
115|              <strong>Antar Jemput Same Day</strong>
116|              <p>Order sebelum jam 15:00, kasur sampai hari ini. Gratis jemput setelah sewa selesai</p>
117|            </div>
118|          </div>
119|          <div class="feature-item">
120|            <span class="feature-check">✅</span>
121|            <div>
122|              <strong>Diskon Sewa Banyak</strong>
123|              <p>3-5 unit: diskon 10% • 6+ unit: diskon 15% — cocok untuk acara</p>
124|            </div>
125|          </div>
126|        </div>
127|      </div>
128|    </section>
129|
130|    <!-- CTA -->
131|    <section class="lipat-cta">
132|      <div class="container">
133|        <h2 class="lipat-cta-title">Butuh kasur lipat sekarang?</h2>
134|        <p class="lipat-cta-desc">Order via WhatsApp — bisa antar hari ini!</p>
135|        <div class="lipat-cta-buttons">
136|          <a href="/produk" class="btn btn-primary btn-lg">Pilih Kasur</a>
137|          <a
138|            href={`https://wa.me/${config.whatsappNumber}?text=Halo%20Santi%20Mebel,%20saya%20mau%20sewa%20kasur%20lipat%20untuk%20[kebutuhan]`}
139|            class="btn btn-outline btn-lg lipat-cta-wa"
140|            target="_blank"
141|            rel="noopener"
142|            data-wa-source="lipat_page"
143|          >
144|            💬 Chat WhatsApp
145|          </a>
146|        </div>
147|      </div>
148|    </section>
149|  </main>
150|
151|  <StickyWhatsApp />
152|</MainLayout>
