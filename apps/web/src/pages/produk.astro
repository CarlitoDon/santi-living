---
export const prerender = true;

import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import PriceList from "@/components/PriceList.astro";
import StickyWhatsApp from "@/components/StickyWhatsApp.astro";
---

<MainLayout
  title="Sewa Kasur Jogja Terdekat | Harga Mulai Rp25rb/hari - Gratis Ongkir"
  description="Pilih kasur untuk disewa di Jogja. ✅ Kasur bersih & steril ✅ Antar 2-4 jam ✅ Mulai Rp25.000/hari ✅ Gratis ongkir area Godean. Order via WhatsApp sekarang!"
>
  <Header />
  <Sidebar />

  <main style="padding-top: 70px;">
    <!-- Price List - Jenis Kasur + Harga -->
    <PriceList />
  </main>

  <!-- Sticky WhatsApp CTA for mobile -->
  <StickyWhatsApp />
</MainLayout>
