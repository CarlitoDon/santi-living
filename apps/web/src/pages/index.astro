---
export const prerender = true;

import MainLayout from "@/layouts/MainLayout.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import Hero from "@/components/Hero.astro";
import ProblemSolution from "@/components/ProblemSolution.astro";
import Benefits from "@/components/Benefits.astro";
import Calculator from "@/components/CalculatorWrapper.astro";
import TargetAudience from "@/components/TargetAudience.astro";
import HowToRent from "@/components/HowToRent.astro";
import ServiceArea from "@/components/ServiceArea.astro";
import Testimonials from "@/components/Testimonials.astro";
import FAQ from "@/components/FAQ.astro";
import LongFormContent from "@/components/LongFormContent.astro";
import FinalCTA from "@/components/FinalCTA.astro";
import StickyWhatsApp from "@/components/StickyWhatsApp.astro";
---

<MainLayout
  title="Sewa Kasur Busa Jogja Murah Mulai Rp25rb | Antar Hari Ini"
  description="Sewa kasur busa bersih di Jogja mulai Rp25.000/hari. Antar jemput same day. Kasur busa premium & steril. Sewa kasur jogja terpercaya by Santi Mebel!"
>
  <Header />
  <Sidebar />

  <main style="padding-top: 70px;">
    <!-- Hero Section with primary CTA -->
    <Hero />

    <!-- Problem → Solution -->
    <ProblemSolution />

    <!-- Calculator - Interactive pricing -->
    <Calculator />

    <!-- Keunggulan Utama -->
    <Benefits />

    <!-- Target Audience -->
    <TargetAudience />

    <!-- How to Rent - 5 steps -->
    <HowToRent />

    <!-- Service Area - Jogja coverage -->
    <ServiceArea />

    <!-- Testimonials - Trust signals -->
    <Testimonials />

    <!-- FAQ Section with Schema -->
    <FAQ />

    <!-- Long-form SEO Content -->
    <LongFormContent />

    <!-- Final CTA -->
    <FinalCTA />
  </main>

  <!-- Sticky WhatsApp CTA for mobile -->
  <StickyWhatsApp />
</MainLayout>
