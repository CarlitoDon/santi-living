---
import CopyButton from "./CopyButton.astro";
import config from "@/data/config.json";

interface Props {
  amount: number;
  class?: string;
}

const { amount, class: className = "" } = Astro.props;
const { bca } = config.payment;

const formatCurrency = (value: number) => {
  return new Intl.NumberFormat("id-ID").format(value);
};
---

<div class={`payment-method-card payment-bca ${className}`}>
  <div class="payment-header">
    <span class="payment-icon">🏦</span>
    <h4 class="payment-title">Transfer BCA</h4>
  </div>

  <div class="payment-details">
    <div class="detail-row">
      <span class="detail-label">Bank</span>
      <span class="detail-value">{bca.bank}</span>
    </div>

    <div class="detail-row">
      <span class="detail-label">Nama Rekening</span>
      <span class="detail-value">{bca.accountName}</span>
    </div>

    <div class="detail-row with-copy">
      <div class="detail-info">
        <span class="detail-label">Nomor Rekening</span>
        <span class="detail-value account-number">{bca.accountNumber}</span>
      </div>
      <CopyButton value={bca.accountNumber} label="Copy" />
    </div>

    <div class="detail-row with-copy amount-row">
      <div class="detail-info">
        <span class="detail-label">Jumlah Transfer</span>
        <span class="detail-value amount">Rp {formatCurrency(amount)}</span>
      </div>
      <CopyButton value={amount.toString()} label="Copy" />
    </div>
  </div>

  <div class="payment-note">
    <p>
      ⚠️ Transfer sesuai nominal di atas agar pembayaran dapat terverifikasi.
    </p>
  </div>
</div>

<style>
  .payment-method-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    border: 2px solid var(--color-primary);
  }

  .payment-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .payment-icon {
    font-size: var(--font-size-xl);
  }

  .payment-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin: 0;
  }

  .payment-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .detail-row.with-copy {
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--color-background);
    border-radius: var(--radius-md);
  }

  .detail-info {
    flex: 1;
    min-width: 0;
  }

  .detail-label {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }

  .detail-value {
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .detail-value.account-number {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    font-family: var(--font-mono, monospace);
    letter-spacing: 0.05em;
  }

  .detail-value.amount {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .amount-row {
    border: 2px solid var(--color-primary-light);
    background: var(--color-primary-light);
  }

  .payment-note {
    margin-top: var(--space-4);
    padding: var(--space-3);
    background: var(--color-warning-light, #fef3c7);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    color: var(--color-warning-dark, #92400e);
  }

  .payment-note p {
    margin: 0;
  }
</style>
