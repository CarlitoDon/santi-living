---

---

<div class="product-modal" id="productModal">
  <div class="product-modal-overlay"></div>
  <div class="product-modal-content">
    <button type="button" class="product-modal-close" id="productModalClose"
      >&times;</button
    >
    <img class="product-modal-image" id="productModalImage" src="" alt="" />
    <div class="product-modal-body">
      <h3 class="product-modal-title" id="productModalTitle"></h3>
      <p class="product-modal-description" id="productModalDescription"></p>
      <div class="product-modal-details" id="productModalDetailsGroup">
        <span class="product-modal-dimensions" id="productModalDimensions"
        ></span>
        <span class="product-modal-capacity" id="productModalCapacity"></span>
      </div>
      <div class="product-modal-price" id="productModalPrice"></div>
    </div>

    <div class="product-modal-footer">
      <div id="modalStepper" class="modal-stepper" style="display: none;">
        <span class="stepper-label">Jumlah:</span>
        <div class="stepper-controls">
          <button type="button" class="btn-stepper btn-minus" id="modalBtnMinus"
            >−</button
          >
          <span class="stepper-qty" id="modalQtyDisplay">0</span>
          <button type="button" class="btn-stepper btn-plus" id="modalBtnPlus"
            >+</button
          >
        </div>
      </div>
      <a
        href="/#calculator"
        id="modalCtaLink"
        class="btn btn-primary btn-lg modal-cta"
        style="display: none;"
      >
        Sewa Kasur Busa Ini
      </a>
    </div>
  </div>
</div>

<style>
  .product-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    display: none;
  }

  .product-modal.active {
    display: block;
  }

  .product-modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    animation: fadeIn 0.2s ease;
  }

  .product-modal-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 400px;
    max-height: 85vh;
    background: var(--color-surface-elevated);
    border-radius: var(--radius-xl);
    overflow: hidden;
    animation: slideUp 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translate(-50%, -45%);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
  }

  .product-modal-close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    width: 32px;
    height: 32px;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    border-radius: var(--radius-full);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    z-index: 10;
  }

  .product-modal-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .product-modal-body {
    padding: var(--space-4);
  }

  .product-modal-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
  }

  .product-modal-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .product-modal-details {
    display: flex;
    gap: var(--space-3);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .product-modal-price {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  /* Modal Footer Enhancements */
  .product-modal-footer {
    padding: var(--space-4);
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .modal-stepper {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
    justify-content: space-between;
  }

  .stepper-label {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .stepper-controls {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--color-background);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  .stepper-qty {
    min-width: 2rem;
    text-align: center;
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-lg);
  }

  .modal-cta {
    width: 100%;
    text-align: center;
    text-decoration: none;
  }
</style>
