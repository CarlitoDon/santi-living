---
/**
 * CalculatorWrapper.astro
 * Bridges Astro's image optimization with React Calculator component
 */
import { getImage } from "astro:assets";
import products from "@/data/products.json";
import { Calculator } from "@/components/calculator";
import { ProductModal } from "@/components/react/ProductModal";

// Import all product images
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp}",
);

// Pre-resolve all product images to optimized URLs
const allProducts = [
  ...products.mattressPackages,
  ...products.mattressOnly,
  ...products.accessories,
];

const imageMap: Record<string, string> = {};
for (const product of allProducts) {
  const imagePath = `/src/assets${product.image}`;
  if (images[imagePath]) {
    const imageModule = await images[imagePath]();
    const optimized = await getImage({
      src: imageModule.default,
      width: 200,
      height: 200,
    });
    imageMap[product.id] = optimized.src;
  }
}

// Prepare products with proper typing for React component
const productsData = {
  mattressPackages: products.mattressPackages.map((p) => ({
    ...p,
    category: "package" as const,
  })),
  mattressOnly: products.mattressOnly.map((p) => ({
    ...p,
    category: "mattress" as const,
  })),
  accessories: products.accessories.map((p) => ({
    ...p,
    category: "accessory" as const,
  })),
};
---

<Calculator client:load products={productsData} imageMap={imageMap} />

<!-- Product Modal (shared) -->
<ProductModal client:idle />

<script>
  import { openMapPicker } from "@/scripts/map-picker";

  // Initialize map picker when open event is dispatched
  window.addEventListener("open-map-picker", () => {
    openMapPicker({
      onConfirm: (coords, address) => {
        // Dispatch event back to React component with location data
        window.dispatchEvent(
          new CustomEvent("location-selected", {
            detail: { coords, address },
          }),
        );
      },
    });
  });
</script>
