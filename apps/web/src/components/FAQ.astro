1|---
2|/**
3| * FAQ Component with FAQ Schema markup for SEO
4| * Targeting: "sewa kasur jogja" keyword
5| */
6|
7|interface FAQItem {
8|  question: string;
9|  answer: string;
10|}
11|
12|const faqs: FAQItem[] = [
13|  {
14|    question: "Berapa harga sewa kasur di Jogja?",
15|    answer:
16|      "Harga sewa kasur di Jogja mulai dari Rp30.000/hari untuk kasur single dan Rp40.000/hari untuk kasur double. Kami juga memberikan diskon 10-15% untuk penyewaan lebih dari 3 unit atau durasi lebih dari 1 minggu.",
17|  },
18|  {
19|    question: "Bagaimana cara menyewa kasur?",
20|    answer:
21|      "Sangat mudah! Cukup pilih jenis kasur dan durasi sewa di website kami, lalu lanjutkan ke checkout. Anda juga bisa langsung hubungi WhatsApp kami di 0895-1911-9092 untuk pemesanan cepat.",
22|  },
23|  {
24|    question: "Apakah bisa antar kasur hari ini?",
25|    answer:
26|      "Ya, kami melayani pengantaran same day untuk pemesanan sebelum jam 15:00. Untuk area Kota Yogyakarta, Sleman, dan Bantul, kasur bisa sampai dalam hitungan jam setelah konfirmasi pembayaran.",
27|  },
28|  {
29|    question: "Area mana saja yang dilayani untuk sewa kasur?",
30|    answer:
31|      "Kami melayani seluruh wilayah Yogyakarta meliputi Kota Yogyakarta, Kabupaten Sleman, Kabupaten Bantul, dan sekitarnya. Untuk area di luar jangkauan, silakan hubungi kami untuk informasi ongkir.",
32|  },
33|  {
34|    question: "Apakah kasur yang disewakan bersih dan higienis?",
35|    answer:
36|      "Tentu! Semua kasur kami dicuci profesional dan didisinfektan setelah setiap pemakaian. Kasur diantar dalam kondisi bersih, wangi, dan dibungkus plastik untuk menjaga kebersihan.",
37|  },
38|  {
39|    question: "Berapa lama minimal durasi sewa kasur?",
40|    answer:
41|      "Minimal sewa kasur adalah 1 hari. Anda bisa menyewa kasur harian, mingguan, atau bulanan sesuai kebutuhan. Semakin lama durasi sewa, semakin hemat biayanya.",
42|  },
43|  {
44|    question: "Bagaimana proses pengembalian kasur?",
45|    answer:
46|      "Anda tidak perlu repot mengembalikan kasur. Cukup hubungi kami via WhatsApp, dan tim kami akan menjemput kasur di lokasi Anda sesuai jadwal yang disepakati. Gratis jemput untuk area Jogja!",
47|  },
48|  {
49|    question: "Apakah ada ongkir untuk pengantaran kasur?",
50|    answer:
51|      "Untuk area dalam radius 3 km dari lokasi kami, pengantaran GRATIS. Untuk area yang lebih jauh, ongkir dihitung berdasarkan jarak dengan tarif Rp1.500/km. Anda bisa cek estimasi ongkir di kalkulator kami.",
52|  },
53|];
54|
55|// Generate FAQ Schema
56|const faqSchema = {
57|  "@context": "https://schema.org",
58|  "@type": "FAQPage",
59|  mainEntity: faqs.map((faq) => ({
60|    "@type": "Question",
61|    name: faq.question,
62|    acceptedAnswer: {
63|      "@type": "Answer",
64|      text: faq.answer,
65|    },
66|  })),
67|};
68|---
69|
70|<section class="faq-section" id="faq">
71|  <div class="container">
72|    <h2 class="section-title">Pertanyaan Seputar Sewa Kasur Jogja</h2>
73|    <p class="section-subtitle">
74|      Temukan jawaban untuk pertanyaan yang sering diajukan
75|    </p>
76|
77|    <div class="faq-list">
78|      {
79|        faqs.map((faq, index) => (
80|          <details class="faq-item" data-index={index}>
81|            <summary class="faq-question">
82|              <span class="faq-icon">+</span>
83|              {faq.question}
84|            </summary>
85|            <div class="faq-answer">
86|              <p>{faq.answer}</p>
87|            </div>
88|          </details>
89|        ))
90|      }
91|    </div>
92|  </div>
93|</section>
94|
95|<!-- FAQ Schema for SEO -->
96|<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
