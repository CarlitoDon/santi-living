185|    }
186|  }
187|</style>
188|
189|<script>
190|  // Accordion behavior - close other items when one opens
191|  document.querySelectorAll(".faq-item").forEach((item) => {
192|    item.addEventListener("toggle", (e) => {
193|      if ((e.target as HTMLDetailsElement).open) {
194|        document.querySelectorAll(".faq-item").forEach((other) => {
195|          if (other !== e.target && (other as HTMLDetailsElement).open) {
196|            (other as HTMLDetailsElement).open = false;
197|          }
198|        });
199|      }
200|    });
201|  });
202|</script>
