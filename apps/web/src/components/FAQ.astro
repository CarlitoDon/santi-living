131|
132|  .faq-question {
133|    display: flex;
134|    align-items: center;
135|    gap: var(--space-3);
136|    padding: var(--space-4) var(--space-5);
137|    cursor: pointer;
138|    font-weight: var(--font-weight-semibold);
139|    color: var(--color-gray-800);
140|    list-style: none;
141|    transition: background 0.2s;
142|  }
143|
144|  .faq-question::-webkit-details-marker {
145|    display: none;
146|  }
147|
148|  .faq-question:hover {
149|    background: var(--color-gray-50);
150|  }
151|
152|  .faq-icon {
153|    display: flex;
154|    align-items: center;
155|    justify-content: center;
156|    width: 24px;
157|    height: 24px;
158|    background: var(--color-primary);
159|    color: white;
