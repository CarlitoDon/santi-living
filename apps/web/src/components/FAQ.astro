98|<style>
99|  .faq-section {
100|    padding: var(--space-16) 0;
101|    background: var(--color-gray-50);
102|  }
103|
104|  .section-title {
105|    text-align: center;
106|    font-size: var(--font-size-2xl);
107|    color: var(--color-gray-900);
108|    margin-bottom: var(--space-2);
109|  }
110|
111|  .section-subtitle {
112|    text-align: center;
113|    color: var(--color-gray-600);
114|    margin-bottom: var(--space-8);
115|  }
116|
117|  .faq-list {
118|    max-width: 800px;
119|    margin: 0 auto;
120|    display: flex;
121|    flex-direction: column;
122|    gap: var(--space-3);
123|  }
124|
125|  .faq-item {
