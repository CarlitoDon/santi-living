# Example Environment for Vercel (Frontend)
# Copy this file to .env, .env.staging, or .env.production

# URL to the Proxy Service (Railway)
SANTI_PROXY_URL="https://your-proxy-service.up.railway.app"

# Proxy Authentication
PROXY_API_SECRET="your_proxy_api_secret"

# Sync ERP Services
SYNC_ERP_API_URL="https://your-api-service.up.railway.app/api/trpc"
SYNC_ERP_API_SECRET="your_sync_erp_api_secret"

# Bot Service
SYNC_ERP_BOT_URL="https://your-bot-service.up.railway.app"
SYNC_ERP_BOT_SECRET="your_sync_erp_bot_secret"

# Midtrans
MIDTRANS_IS_PRODUCTION="false"
MIDTRANS_CLIENT_KEY="your_midtrans_client_key"
