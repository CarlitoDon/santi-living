{
  "name": "erp-sync-service",
  "version": "1.0.0",
  "description": "Bridge service between santi-living and sync-erp",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "sync-bundles": "ts-node src/scripts/sync-bundles.ts"
  },
  "dependencies": {
    "@sync-erp/shared": "file:../../../sync-erp/packages/shared",
    "@trpc/client": "^11.5.0",
    "@trpc/server": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "superjson": "^2.2.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
