{
  "name": "santi-living",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@santi-living/web",
    "dev:proxy": "turbo run dev --filter=@santi-living/proxy",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@santi-living/web",
    "build:proxy": "turbo run build --filter=@santi-living/proxy",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.5.4"
  },
  "packageManager": "npm@10.8.2"
}
