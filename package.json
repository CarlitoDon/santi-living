{
  "name": "santi-living",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "cd apps/web-next && npm run dev",
    "dev:proxy": "cd apps/proxy && npm run dev",
    "build": "cd apps/web-next && npm run build",
    "build:web": "cd apps/web-next && npm run build",
    "build:proxy": "cd apps/proxy && npm run build",
    "lint": "cd apps/web-next && npm run lint",
    "test": "cd apps/web-next && npm test",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/.next apps/*/dist"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "packageManager": "npm@10.8.2"
}
