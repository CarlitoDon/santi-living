# Environment Template - Copy to .env

# ========================================
# Service URLs
# ========================================

# Santi Living Proxy Service URL
SANTI_PROXY_URL="https://your-proxy-service.up.railway.app"

# Sync ERP API URL
SYNC_ERP_API_URL="https://your-erp-api-service.up.railway.app/api/trpc"

# Sync ERP Bot URL
SYNC_ERP_BOT_URL="https://your-bot-service.up.railway.app"

# ========================================
# Authentication Secrets
# ========================================

# Auth to santi-living Proxy (for frontend)
PROXY_API_SECRET="your_proxy_api_secret"

# Auth to sync-erp API (from santi-living)
SYNC_ERP_API_SECRET="your_sync_erp_api_secret"

# Auth to sync-erp Bot (from santi-living)
SYNC_ERP_BOT_SECRET="your_sync_erp_bot_secret"

# ========================================
# Admin Settings
# ========================================

# Admin WhatsApp for notifications (62 format without +)
ADMIN_WHATSAPP_NUMBER="62xxxxxxxxxxx"
