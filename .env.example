# Production Environment for Vercel (Frontend)

# URL to the Proxy Service (Railway)
# CHANGE THIS to your actual Railway Service URL
PUBLIC_PROXY_URL="https://your-proxy-service.up.railway.app"
PROXY_SERVICE_URL="https://your-proxy-service.up.railway.app"

# Secret Key (Must match apps/proxy/.env.production)
PROXY_API_KEY="your_proxy_api_key"

# Legacy / SSR Direct Connection to Sync ERP (Required for [token].astro)
ERP_SYNC_SERVICE_URL="https://your-erp-api-service.up.railway.app"
BOT_SECRET="your_bot_secret"

# Bot Service
PUBLIC_BOT_API_URL="https://your-bot-service.up.railway.app"
