---
import MainLayout from "@/layouts/MainLayout.astro";
import config from "@/data/config.json";
---

<MainLayout title="Terima Kasih - Sewa Kasur Jogja">
  <main class="thank-you-page">
    <div class="container">
      <div class="thank-you-card">
        <div class="success-icon">✅</div>

        <h1 class="thank-you-title">Terima Kasih!</h1>

        <p class="thank-you-message">
          Pesanan Anda sedang kami proses. Admin akan segera menghubungi Anda
          melalui WhatsApp untuk konfirmasi pengiriman.
        </p>

        <div class="instruction-box">
          <h3>📸 Langkah Selanjutnya</h3>
          <ol>
            <li>Lakukan pembayaran sesuai metode yang dipilih</li>
            <li>Kirim bukti pembayaran via WhatsApp</li>
            <li>Tunggu konfirmasi dari admin</li>
          </ol>
        </div>

        <div class="action-buttons">
          <a href="#" class="btn btn-whatsapp btn-lg" id="btnWhatsApp">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            Kirim Bukti Pembayaran
          </a>

          <a href="/sewa-kasur" class="btn btn-secondary">
            Kembali ke Beranda
          </a>
        </div>

        <p class="fallback-text">
          Jika tab WhatsApp tidak terbuka, klik tombol di atas atau hubungi
          langsung:
          <strong>{config.whatsappDisplay}</strong>
        </p>
      </div>
    </div>
  </main>

  <script>
    import {
      getOrder,
      clearOrder,
      getPaymentMethod,
    } from "@/scripts/checkout-session";
    import config from "@/data/config.json";

    // Get order data before clearing
    const session = getOrder();
    const paymentMethod = getPaymentMethod();

    // Clear session storage
    clearOrder();

    // Set up WhatsApp button
    const btnWhatsApp = document.getElementById("btnWhatsApp");

    if (btnWhatsApp && session) {
      const { order } = session;
      const method = paymentMethod === "bca" ? "Transfer BCA" : "QRIS";

      const message = `Halo Santi Living,

Saya *${order.customerName}* ingin konfirmasi pembayaran untuk pesanan sewa kasur:

📦 *Detail Pesanan:*
${order.items.map((item: any) => `- ${item.name} (${item.quantity}x)`).join("\n")}

⏱ Durasi: ${order.duration} hari
📅 Mulai: ${order.orderDate}
💰 Total: Rp ${new Intl.NumberFormat("id-ID").format(order.totalPrice)}
💳 Metode: ${method}

📍 Alamat: ${order.deliveryAddress}

*Berikut bukti pembayaran saya:*
[Kirim foto bukti transfer/screenshot pembayaran]

Terima kasih! 🙏`;

      const encodedMessage = encodeURIComponent(message);
      const waUrl = `https://wa.me/${config.whatsappNumber}?text=${encodedMessage}`;

      btnWhatsApp.setAttribute("href", waUrl);
      btnWhatsApp.setAttribute("target", "_blank");
    } else {
      // Fallback - just open WhatsApp without context
      if (btnWhatsApp) {
        btnWhatsApp.setAttribute(
          "href",
          `https://wa.me/${config.whatsappNumber}`
        );
        btnWhatsApp.setAttribute("target", "_blank");
      }
    }
  </script>
</MainLayout>

<style>
  .thank-you-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
    background: linear-gradient(
      to bottom,
      var(--color-primary-light) 0%,
      var(--color-background) 50%
    );
  }

  .thank-you-card {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    max-width: 500px;
    width: 100%;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  }

  .success-icon {
    font-size: 4rem;
    margin-bottom: var(--space-4);
    animation: bounce 0.6s ease;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .thank-you-title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .thank-you-message {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .instruction-box {
    background: var(--color-background);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    margin-bottom: var(--space-6);
    text-align: left;
  }

  .instruction-box h3 {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .instruction-box ol {
    margin: 0;
    padding-left: var(--space-4);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
  }

  .instruction-box li {
    margin-bottom: var(--space-2);
  }

  .instruction-box li:last-child {
    margin-bottom: 0;
  }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .btn-whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: var(--color-whatsapp);
    color: white;
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
    transition: all 0.2s;
    min-height: 56px;
  }

  .btn-whatsapp:hover {
    background: var(--color-whatsapp-dark);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: block;
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    transition: all 0.2s;
    min-height: 44px;
  }

  .btn-secondary:hover {
    background: var(--color-background);
    color: var(--color-text);
  }

  .fallback-text {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .fallback-text strong {
    color: var(--color-text);
  }
</style>
