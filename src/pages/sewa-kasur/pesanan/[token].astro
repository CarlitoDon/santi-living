---
import MainLayout from "@/layouts/MainLayout.astro";
import config from "@/data/config.json";

// Get token from URL
const { token } = Astro.params;

// Fetch order from erp-sync-service (server-side)
let order = null;
let error = null;

if (token) {
  try {
    const apiUrl = import.meta.env.ERP_SYNC_SERVICE_URL || "http://localhost:3001";
    const response = await fetch(`${apiUrl}/api/orders/${token}`);
    if (response.ok) {
      order = await response.json();
    } else {
      error = "Pesanan tidak ditemukan";
    }
  } catch (e) {
    error = "Gagal memuat data pesanan";
  }
}

// Status badge colors
const statusColors: Record<string, { bg: string; text: string; label: string }> = {
  DRAFT: { bg: "#FEF3C7", text: "#92400E", label: "Menunggu Konfirmasi" },
  PENDING: { bg: "#FEF3C7", text: "#92400E", label: "Menunggu Konfirmasi" },
  CONFIRMED: { bg: "#DBEAFE", text: "#1E40AF", label: "Dikonfirmasi" },
  ACTIVE: { bg: "#D1FAE5", text: "#065F46", label: "Aktif (Sedang Disewa)" },
  COMPLETED: { bg: "#E5E7EB", text: "#374151", label: "Selesai" },
  CANCELLED: { bg: "#FEE2E2", text: "#991B1B", label: "Dibatalkan" },
};

const status = order?.status || "PENDING";
const statusInfo = statusColors[status] || statusColors.PENDING;

// Format helpers
const formatCurrency = (amount: number) => 
  new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", minimumFractionDigits: 0 }).format(amount);

const formatDate = (dateStr: string) =>
  new Date(dateStr).toLocaleDateString("id-ID", { weekday: "long", year: "numeric", month: "long", day: "numeric" });
---

<MainLayout title={order ? `Pesanan ${order.orderNumber}` : "Pesanan Tidak Ditemukan"}>
  <main class="order-page">
    <div class="container">
      {error ? (
        <div class="error-card">
          <div class="error-icon">❌</div>
          <h1>Pesanan Tidak Ditemukan</h1>
          <p>{error}</p>
          <a href="/sewa-kasur" class="btn btn-primary">Kembali ke Beranda</a>
        </div>
      ) : order ? (
        <div class="order-card">
          <!-- Header -->
          <div class="order-header">
            <div class="order-number">
              <span class="label">Nomor Pesanan</span>
              <span class="value">{order.orderNumber}</span>
            </div>
            <div class="status-badge" style={`background: ${statusInfo.bg}; color: ${statusInfo.text}`}>
              {statusInfo.label}
            </div>
          </div>

          <!-- Progress Steps -->
          <div class="progress-steps">
            <div class={`step ${["DRAFT", "PENDING", "CONFIRMED", "ACTIVE", "COMPLETED"].includes(status) ? "active" : ""}`}>
              <div class="step-icon">📝</div>
              <span>Pesanan Dibuat</span>
            </div>
            <div class="step-line"></div>
            <div class={`step ${["CONFIRMED", "ACTIVE", "COMPLETED"].includes(status) ? "active" : ""}`}>
              <div class="step-icon">✅</div>
              <span>Dikonfirmasi</span>
            </div>
            <div class="step-line"></div>
            <div class={`step ${["ACTIVE", "COMPLETED"].includes(status) ? "active" : ""}`}>
              <div class="step-icon">🚚</div>
              <span>Dikirim</span>
            </div>
            <div class="step-line"></div>
            <div class={`step ${status === "COMPLETED" ? "active" : ""}`}>
              <div class="step-icon">🎉</div>
              <span>Selesai</span>
            </div>
          </div>

          <!-- Order Details -->
          <div class="section">
            <h3>📦 Detail Pesanan</h3>
            <div class="items-list">
              {order.items.map((item: any) => (
                <div class="item-row">
                  <span class="item-name">{item.name}</span>
                  <span class="item-qty">{item.quantity}x</span>
                  <span class="item-price">{formatCurrency(item.pricePerDay * item.quantity)}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Dates -->
          <div class="section">
            <h3>📅 Periode Sewa</h3>
            <div class="date-row">
              <span class="label">Mulai</span>
              <span class="value">{formatDate(order.rentalStartDate)}</span>
            </div>
            <div class="date-row">
              <span class="label">Selesai</span>
              <span class="value">{formatDate(order.rentalEndDate)}</span>
            </div>
          </div>

          <!-- Delivery Address -->
          {order.deliveryAddress && (
            <div class="section">
              <h3>📍 Alamat Pengiriman</h3>
              <p class="address-text">{order.deliveryAddress}</p>
            </div>
          )}

          <!-- Total -->
          <div class="section total-section">
            <div class="total-row">
              <span>Subtotal</span>
              <span>{formatCurrency(order.subtotal)}</span>
            </div>
            {order.discountAmount && order.discountAmount > 0 && (
              <div class="total-row discount">
                <span>Diskon {order.discountLabel || ""}</span>
                <span>-{formatCurrency(order.discountAmount)}</span>
              </div>
            )}
            {order.deliveryFee && order.deliveryFee > 0 && (
              <div class="total-row">
                <span>Biaya Antar</span>
                <span>{formatCurrency(order.deliveryFee)}</span>
              </div>
            )}
            <div class="total-row grand-total">
              <span>Total</span>
              <span>{formatCurrency(order.totalAmount)}</span>
            </div>
          </div>

          <!-- Payment Instructions -->
          {status === "DRAFT" || status === "PENDING" ? (
            <div class="section payment-section">
              <h3>💳 Instruksi Pembayaran</h3>
              {order.paymentMethod === "qris" ? (
                <div class="payment-info">
                  <p>Scan QRIS di bawah untuk pembayaran:</p>
                  <div class="qris-placeholder">
                    <span>QRIS akan dikirim via WhatsApp</span>
                  </div>
                </div>
              ) : (
                <div class="payment-info">
                  <p>Transfer ke rekening:</p>
                  <div class="bank-info">
                    <strong>BCA 0123456789</strong>
                    <span>a.n. Santi Living</span>
                  </div>
                </div>
              )}
            </div>
          ) : null}

          <!-- Contact -->
          <div class="action-buttons">
            <a href={`https://wa.me/${config.whatsappNumber}`} class="btn btn-whatsapp" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path>
              </svg>
              Hubungi Kami
            </a>
            <a href="/sewa-kasur" class="btn btn-secondary">Kembali ke Beranda</a>
          </div>
        </div>
      ) : (
        <div class="loading-card">
          <div class="spinner"></div>
          <p>Memuat pesanan...</p>
        </div>
      )}
    </div>
  </main>
</MainLayout>

<style>
  .order-page {
    min-height: 100vh;
    padding: var(--space-6);
    background: linear-gradient(to bottom, var(--color-primary-light) 0%, var(--color-background) 30%);
  }

  .container {
    max-width: 600px;
    margin: 0 auto;
  }

  .order-card, .error-card, .loading-card {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  }

  .error-card, .loading-card {
    text-align: center;
    padding: var(--space-8);
  }

  .error-icon { font-size: 3rem; margin-bottom: var(--space-4); }

  .order-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .order-number .label {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .order-number .value {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .status-badge {
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
  }

  .progress-steps {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: var(--color-background);
    border-radius: var(--radius-lg);
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    opacity: 0.4;
    font-size: var(--font-size-xs);
  }

  .step.active { opacity: 1; }
  .step-icon { font-size: 1.2rem; }
  .step-line { flex: 1; height: 2px; background: var(--color-border); margin: 0 var(--space-1); }

  .section {
    margin-bottom: var(--space-5);
  }

  .section h3 {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .items-list {
    background: var(--color-background);
    border-radius: var(--radius-md);
    padding: var(--space-3);
  }

  .item-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) 0;
    font-size: var(--font-size-sm);
  }

  .item-row:not(:last-child) { border-bottom: 1px solid var(--color-border); }
  .item-name { flex: 1; color: var(--color-text); }
  .item-qty { color: var(--color-text-muted); margin-right: var(--space-3); }
  .item-price { font-weight: var(--font-weight-medium); color: var(--color-text); }

  .date-row {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-sm);
    padding: var(--space-2) 0;
  }

  .date-row .label { color: var(--color-text-muted); }
  .date-row .value { color: var(--color-text); }

  .address-text {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    background: var(--color-background);
    padding: var(--space-3);
    border-radius: var(--radius-md);
  }

  .total-section {
    background: var(--color-background);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
  }

  .total-row {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-sm);
    padding: var(--space-2) 0;
  }

  .total-row.discount { color: var(--color-success); }
  .total-row.grand-total {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
    margin-top: var(--space-2);
  }

  .payment-section {
    background: var(--color-primary-light);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
  }

  .payment-info p { font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-bottom: var(--space-3); }

  .qris-placeholder, .bank-info {
    background: var(--color-surface);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .bank-info { display: flex; flex-direction: column; gap: var(--space-1); }
  .bank-info strong { font-size: var(--font-size-lg); color: var(--color-text); }
  .bank-info span { font-size: var(--font-size-sm); color: var(--color-text-muted); }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .btn-whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: var(--color-whatsapp);
    color: white;
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
    transition: all 0.2s;
  }

  .btn-whatsapp:hover { background: var(--color-whatsapp-dark); transform: translateY(-2px); }

  .btn-secondary {
    display: block;
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    text-align: center;
    transition: all 0.2s;
  }

  .btn-secondary:hover { background: var(--color-background); color: var(--color-text); }

  .btn-primary {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    margin-top: var(--space-4);
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto var(--space-4);
  }

  @keyframes spin { to { transform: rotate(360deg); } }
</style>
