---
import MainLayout from "@/layouts/MainLayout.astro";
import config from "@/data/config.json";

// Disable prerender - dynamic page
export const prerender = false;

// Get token from URL
const { token } = Astro.params;

// Fetch order to show details
let order = null;
let error = null;

if (token) {
  try {
    // Use sync-erp API (port 3001)
    const apiUrl =
      import.meta.env.ERP_SYNC_SERVICE_URL || "http://localhost:3001";
    // TRPC batch format for GET: URL needs ?batch=1&input={"0":{"json":{...}}}
    const input = encodeURIComponent(
      JSON.stringify({ "0": { json: { token } } }),
    );
    const response = await fetch(
      `${apiUrl}/api/trpc/publicRental.getByToken?batch=1&input=${input}`,
    );
    if (response.ok) {
      const data = await response.json();
      // TRPC batch response: [{"result":{"data":{"json":{...}}}}]
      order = data?.[0]?.result?.data?.json || null;
    } else {
      error = "Pesanan tidak ditemukan";
    }
  } catch (e) {
    error = "Gagal memuat data pesanan";
  }
}

const formatCurrency = (amount: number) =>
  new Intl.NumberFormat("id-ID", {
    style: "currency",
    currency: "IDR",
    minimumFractionDigits: 0,
  }).format(amount);
---

<MainLayout title="Konfirmasi Pembayaran - Sewa Kasur Jogja">
  <main class="thank-you-page">
    <div class="container">
      <div class="thank-you-card">
        <div class="success-icon">✅</div>

        <h1 class="thank-you-title">Terima Kasih!</h1>

        <p class="thank-you-subtitle">
          Konfirmasi pembayaran Anda telah kami terima.
        </p>

        {
          order && (
            <div class="order-summary">
              <div class="order-number">
                <span class="label">Nomor Pesanan</span>
                <span class="value">{order.orderNumber}</span>
              </div>
              <div class="order-total">
                <span class="label">Total Pembayaran</span>
                <span class="value">{formatCurrency(order.totalAmount)}</span>
              </div>
            </div>
          )
        }

        <div class="instruction-box">
          <h3>⏳ Apa yang terjadi selanjutnya?</h3>
          <ol>
            <li>
              Admin kami akan <strong>memverifikasi pembayaran</strong> Anda dalam
              1-24 jam kerja
            </li>
            <li>
              Setelah pembayaran dikonfirmasi, admin akan <strong
                >menghubungi Anda via WhatsApp</strong
              > untuk konfirmasi pengiriman
            </li>
            <li>
              Kasur akan <strong>diantar ke alamat</strong> Anda sesuai jadwal yang
              disepakati
            </li>
          </ol>
        </div>

        <div class="status-notice">
          <div class="notice-icon">🔔</div>
          <p>
            Anda dapat mengecek status pesanan kapan saja dengan mengunjungi
            halaman pesanan Anda.
          </p>
        </div>

        <div class="action-buttons">
          <a
            href={`/sewa-kasur/pesanan/${token}`}
            class="btn btn-primary btn-lg"
          >
            📦 Lihat Status Pesanan
          </a>

          <a
            href={`https://wa.me/${config.whatsappNumber}`}
            class="btn btn-whatsapp"
            target="_blank"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            Hubungi Kami via WhatsApp
          </a>

          <a href="/sewa-kasur" class="btn btn-secondary">
            Kembali ke Beranda
          </a>
        </div>

        <p class="contact-info">
          Ada pertanyaan? Hubungi kami di <strong
            >{config.whatsappDisplay}</strong
          >
        </p>
      </div>
    </div>
  </main>
</MainLayout>

<style>
  .thank-you-page {
    min-height: 100vh;
    padding: var(--space-6);
    background: linear-gradient(
      to bottom,
      #d1fae5 0%,
      var(--color-background) 30%
    );
  }

  .container {
    max-width: 600px;
    margin: 0 auto;
  }

  .thank-you-card {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
    text-align: center;
  }

  .success-icon {
    font-size: 4rem;
    margin-bottom: var(--space-4);
    animation: bounce 0.5s ease-out;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .thank-you-title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .thank-you-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .order-summary {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    padding: var(--space-4);
    background: var(--color-background);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-6);
  }

  .order-summary .label {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .order-summary .value {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .instruction-box {
    text-align: left;
    background: #fef3c7;
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .instruction-box h3 {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-3);
    color: #92400e;
  }

  .instruction-box ol {
    margin: 0;
    padding-left: var(--space-5);
    color: #78350f;
  }

  .instruction-box li {
    margin-bottom: var(--space-2);
    line-height: 1.5;
  }

  .instruction-box li:last-child {
    margin-bottom: 0;
  }

  .status-notice {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    text-align: left;
    background: #dbeafe;
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .notice-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .status-notice p {
    margin: 0;
    font-size: var(--font-size-sm);
    color: #1e40af;
  }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-lg {
    padding: var(--space-4) var(--space-6);
    font-size: var(--font-size-lg);
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
  }

  .btn-whatsapp {
    background: #25d366;
    color: white;
  }

  .btn-whatsapp:hover {
    background: #1da855;
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-background);
  }

  .contact-info {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
