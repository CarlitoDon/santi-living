---
import MenuToggle from "./MenuToggle.astro";
---

<header class="site-header">
  <div class="container">
    <div class="header-content">
      <MenuToggle />
      <div class="header-logo-group">
        <h1 class="site-title">
          <a href="/sewa-kasur" class="logo-link">
            <span class="site-name">Santi Living</span>
            <span class="brand-line">
              <span class="by">by</span>
              <img
                src="/images/logo-santi-mebel.png"
                alt="Santi Mebel Jogja"
                class="brand-logo"
              />
            </span>
          </a>
        </h1>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const header = document.querySelector(".site-header");
      const headerHeight = header ? header.offsetHeight : 80;
      let lastScrollY = Math.max(0, window.scrollY);
      let headerOffset = 0;

      function onScroll() {
        const currentScrollY = Math.max(0, window.scrollY);

        // At top of page or iOS bounce - always show header
        if (currentScrollY <= 0) {
          headerOffset = 0;
        } else {
          const diff = currentScrollY - lastScrollY;
          headerOffset = Math.min(
            Math.max(headerOffset + diff, 0),
            headerHeight,
          );
        }

        header.style.transform = `translateY(-${headerOffset}px)`;
        lastScrollY = currentScrollY;
      }

      window.addEventListener("scroll", onScroll, { passive: true });
    })();
  </script>

  <style>
    .site-header {
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-4) 0;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      will-change: transform;
    }

    .header-content {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      margin-bottom: var(--space-2);
      min-height: 50px;
    }

    .header-content :global(.navigation) {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
    }

    .logo-link {
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .site-title {
      margin: 0;
      line-height: 1.2;
    }

    .site-name {
      display: block;
      font-family: "Noto Serif", serif;
      font-size: var(--font-size-3xl);
      font-weight: var(--font-weight-bold);
      color: var(--color-text);
      letter-spacing: -0.5px;
    }

    .brand-line {
      display: flex;
      align-items: center;
      gap: var(--space-1);
    }

    .by {
      font-size: 10px;
      font-weight: var(--font-weight-normal);
      font-style: italic;
      color: var(--color-text-muted);
    }

    .brand-logo {
      height: 28px;
      width: auto;
      border-radius: var(--radius-sm);
    }

    .site-tagline {
      font-size: var(--font-size-xs);
      color: var(--color-text-secondary);
      margin: 0;
    }

    .text-center {
      text-align: center;
    }

    @media (min-width: 768px) {
      .site-header {
        padding: var(--space-4) 0;
      }

      .site-title {
        font-size: var(--font-size-2xl);
      }

      .logo-link {
        flex-direction: row;
        align-items: center;
        gap: var(--space-3);
      }

      .brand {
        padding: var(--space-1) var(--space-3);
      }

      .brand-name {
        font-size: var(--font-size-base);
      }
    }
  </style>
</header>
