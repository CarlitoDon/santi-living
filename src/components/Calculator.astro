---
import products from "@/data/products.json";
import config from "@/data/config.json";
import ProductModal from "./ProductModal.astro";
import type { ProductItem } from "@/types";

// This is just for type checking in the template if needed,
// though we access products.mattressPackages directly now.
const allProducts = products;

const isLarge = (dimensions?: string) => {
  if (!dimensions) return false;
  const width = parseInt(dimensions.split("x")[0].trim());
  return width > 100;
};
---

<section class="calculator section" id="calculator">
  <div class="container">
    <h2 class="section-title">Hitung Biaya Sewa</h2>

    <div class="calculator-wrapper">
      <form class="calculator-form" id="calculatorForm">
        <!-- Section 1: Pilihan Produk -->
        <div class="form-section">
          <div class="form-section-header">
            <span class="form-section-number">1</span>
            <span class="form-section-title">Pilihan Item</span>
          </div>

          <!-- 1. Paket Kasur -->
          <div class="accordion-item active">
            <button type="button" class="accordion-header">
              <span class="accordion-title"
                >Paket Kasur (Kasur + Bantal + Selimut)</span
              >
              <span class="accordion-icon">−</span>
            </button>
            <div class="accordion-content" style="display: block;">
              <div class="mattress-cart">
                {
                  products.mattressPackages.map((m) => (
                    <div
                      class={`cart-item ${isLarge(m.dimensions) ? "is-large-size" : ""}`}
                      data-id={m.id}
                    >
                      <img
                        class="cart-item-thumb"
                        src={m.image}
                        alt={m.shortName}
                        loading="lazy"
                        data-modal-trigger
                        data-id={m.id}
                        data-name={m.name}
                        data-description={m.description}
                        data-dimensions={m.dimensions}
                        data-capacity={m.capacity}
                        data-price={m.pricePerDay}
                      />
                      <div class="cart-item-info">
                        <span class="cart-item-name">{m.shortName}</span>
                        <span class="cart-item-dimensions">{m.dimensions}</span>
                        <span class="cart-item-price">
                          Rp{" "}
                          {new Intl.NumberFormat("id-ID").format(m.pricePerDay)}
                          /hari
                        </span>
                      </div>
                      <div class="cart-item-controls">
                        <button
                          type="button"
                          class="btn-stepper btn-minus"
                          data-id={m.id}
                          data-category="package"
                        >
                          −
                        </button>
                        <span class="cart-item-qty" data-id={m.id}>
                          0
                        </span>
                        <button
                          type="button"
                          class="btn-stepper btn-plus"
                          data-id={m.id}
                          data-name={m.shortName}
                          data-category="package"
                          data-price={m.pricePerDay}
                        >
                          +
                        </button>
                      </div>
                    </div>
                  ))
                }
              </div>
              <button type="button" class="btn-show-more" data-target="package">
                Lihat Ukuran Lainnya
              </button>
            </div>
          </div>

          <!-- 2. Kasur Saja -->
          <div class="accordion-item">
            <button type="button" class="accordion-header">
              <span class="accordion-title">Kasur Saja</span>
              <span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content" style="display: none;">
              <div class="mattress-cart">
                {
                  products.mattressOnly.map((m) => (
                    <div
                      class={`cart-item ${isLarge(m.dimensions) ? "is-large-size" : ""}`}
                      data-id={m.id}
                    >
                      <img
                        class="cart-item-thumb"
                        src={m.image}
                        alt={m.shortName}
                        loading="lazy"
                        data-modal-trigger
                        data-id={m.id}
                        data-name={m.name}
                        data-description={m.description}
                        data-dimensions={m.dimensions}
                        data-capacity={m.capacity}
                        data-price={m.pricePerDay}
                      />
                      <div class="cart-item-info">
                        <span class="cart-item-name">{m.shortName}</span>
                        <span class="cart-item-dimensions">{m.dimensions}</span>
                        <span class="cart-item-price">
                          Rp{" "}
                          {new Intl.NumberFormat("id-ID").format(m.pricePerDay)}
                          /hari
                        </span>
                      </div>
                      <div class="cart-item-controls">
                        <button
                          type="button"
                          class="btn-stepper btn-minus"
                          data-id={m.id}
                          data-category="mattress"
                        >
                          −
                        </button>
                        <span class="cart-item-qty" data-id={m.id}>
                          0
                        </span>
                        <button
                          type="button"
                          class="btn-stepper btn-plus"
                          data-id={m.id}
                          data-name={m.shortName}
                          data-category="mattress"
                          data-price={m.pricePerDay}
                        >
                          +
                        </button>
                      </div>
                    </div>
                  ))
                }
              </div>
              <button
                type="button"
                class="btn-show-more"
                data-target="mattress"
              >
                Lihat Ukuran Lainnya
              </button>
            </div>
          </div>

          <!-- 3. Aksesoris -->
          <div class="accordion-item">
            <button type="button" class="accordion-header">
              <span class="accordion-title">Ekstra Tambahan Satuan</span>
              <span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content" style="display: none;">
              <div class="mattress-cart">
                {
                  products.accessories.map((item) => (
                    <div class="cart-item" data-id={item.id}>
                      <img
                        class="cart-item-thumb"
                        src={item.image}
                        alt={item.name}
                        loading="lazy"
                        data-modal-trigger
                        data-id={item.id}
                        data-name={item.name}
                        data-description={item.description}
                        data-dimensions=""
                        data-capacity=""
                        data-price={item.pricePerDay}
                      />
                      <div class="cart-item-info">
                        <span class="cart-item-name">{item.name}</span>
                        <span class="cart-item-dimensions">
                          {item.description}
                        </span>
                        <span class="cart-item-price">
                          Rp{" "}
                          {new Intl.NumberFormat("id-ID").format(
                            item.pricePerDay
                          )}
                          /hari
                        </span>
                      </div>
                      <div class="cart-item-controls">
                        <button
                          type="button"
                          class="btn-stepper btn-minus"
                          data-id={item.id}
                          data-category="accessory"
                        >
                          −
                        </button>
                        <span class="cart-item-qty" data-id={item.id}>
                          0
                        </span>
                        <button
                          type="button"
                          class="btn-stepper btn-plus"
                          data-id={item.id}
                          data-name={item.name}
                          data-category="accessory"
                          data-price={item.pricePerDay}
                        >
                          +
                        </button>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>

          <div class="cart-total">
            <span class="cart-total-label">Total Item:</span>
            <span class="cart-total-value" id="cartTotalQty">0 unit</span>
          </div>
          <span class="form-error" id="mattressError"></span>
        </div>

        <!-- Section 2: Jadwal Sewa -->
        <div class="form-section">
          <div class="form-section-header">
            <span class="form-section-number">2</span>
            <span class="form-section-title">Jadwal Sewa</span>
          </div>

          <!-- Duration -->
          <div class="form-group">
            <label class="form-label" for="duration">Lama Sewa (hari)</label>
            <input
              type="number"
              id="duration"
              name="duration"
              class="form-input"
              min="1"
              max="30"
              value="1"
              inputmode="numeric"
            />
            <span class="form-error" id="durationError"></span>
          </div>

          <!-- Start Date -->
          <div class="form-group">
            <label class="form-label" for="startDate">Tanggal Mulai</label>
            <input
              type="date"
              id="startDate"
              name="startDate"
              class="form-input"
            />
            <span class="form-error" id="startDateError"></span>
          </div>
        </div>

        <!-- Section 3: Data Pemesan -->
        <div class="form-section">
          <div class="form-section-header">
            <span class="form-section-number">3</span>
            <span class="form-section-title">Data Pemesan</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="customerName">Nama</label>
            <input
              type="text"
              id="customerName"
              name="customerName"
              class="form-input"
              placeholder="Nama lengkap"
            />
            <span class="form-error" id="customerNameError"></span>
          </div>

          <div class="form-group">
            <label class="form-label" for="customerWhatsapp">No. WhatsApp</label
            >
            <input
              type="tel"
              id="customerWhatsapp"
              name="customerWhatsapp"
              class="form-input"
              placeholder="08xxxxxxxxxx"
              inputmode="tel"
            />
            <span class="form-error" id="customerWhatsappError"></span>
          </div>
        </div>

        <!-- Section 4: Alamat Pengantaran -->
        <div class="form-section">
          <div class="form-section-header">
            <span class="form-section-number">4</span>
            <span class="form-section-title">Alamat Pengantaran</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="addressStreet">Alamat Jalan</label>
            <input
              type="text"
              id="addressStreet"
              name="addressStreet"
              class="form-input"
              placeholder="Nama jalan, nomor rumah, RT/RW"
            />
            <div class="address-buttons">
              <button
                type="button"
                class="btn-location"
                id="locationButton"
                title="Gunakan lokasi GPS saya"
              >
                📍 Gunakan Lokasi Sekarang
              </button>
              <button
                type="button"
                class="btn-map-open"
                id="mapPickerButton"
                title="Pilih lokasi di peta"
              >
                🗺️ Pilih di Peta
              </button>
            </div>
            <span class="form-error" id="addressStreetError"></span>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label class="form-label" for="addressKelurahan"
                >Kelurahan/Desa</label
              >
              <input
                type="text"
                id="addressKelurahan"
                name="addressKelurahan"
                class="form-input"
                placeholder="Kelurahan"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="addressKecamatan">Kecamatan</label>
              <input
                type="text"
                id="addressKecamatan"
                name="addressKecamatan"
                class="form-input"
                placeholder="Kecamatan"
              />
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label class="form-label" for="addressKota">Kabupaten/Kota</label>
              <input
                type="text"
                id="addressKota"
                name="addressKota"
                class="form-input"
                placeholder="Sleman, Bantul, dll"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="addressProvinsi">Provinsi</label>
              <input
                type="text"
                id="addressProvinsi"
                name="addressProvinsi"
                class="form-input"
                value="DI Yogyakarta"
                placeholder="Provinsi"
              />
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label class="form-label" for="addressZip">Kode Pos</label>
              <input
                type="text"
                id="addressZip"
                name="addressZip"
                class="form-input"
                placeholder="55xxx"
                inputmode="numeric"
                maxlength="5"
              />
            </div>
            <div class="form-group">
              <!-- Spacer for alignment -->
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label class="form-label" for="addressLat">Latitude</label>
              <input
                type="text"
                id="addressLat"
                name="addressLat"
                class="form-input form-input-readonly"
                placeholder="Otomatis dari GPS"
                readonly
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="addressLng">Longitude</label>
              <input
                type="text"
                id="addressLng"
                name="addressLng"
                class="form-input form-input-readonly"
                placeholder="Otomatis dari GPS"
                readonly
              />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="customerNotes"
              >Catatan (opsional)</label
            >
            <textarea
              id="customerNotes"
              name="customerNotes"
              class="form-textarea"
              placeholder="Permintaan khusus, jam antar, dll"
              rows="2"></textarea>
          </div>
        </div>

        <!-- Payment method removed - now handled on checkout page -->
      </form>

      <!-- Result Panel -->
      <div class="calculator-result">
        <div class="result-summary">
          <h3 class="result-title">Ringkasan</h3>

          <div class="result-item" id="resultMattress">
            <span class="result-label">Kasur</span>
            <span class="result-value">-</span>
          </div>

          <div class="result-item" id="resultQuantity">
            <span class="result-label">Jumlah</span>
            <span class="result-value">1 unit</span>
          </div>

          <div class="result-item" id="resultDuration">
            <span class="result-label">Durasi</span>
            <span class="result-value">1 hari</span>
          </div>

          <div class="result-item" id="resultDates">
            <span class="result-label">Tanggal</span>
            <span class="result-value">-</span>
          </div>

          <div class="result-item" id="resultDeliveryFee">
            <span class="result-label"
              >Biaya Antar <span
                id="deliveryDistance"
                class="text-sm text-gray-500 font-normal"></span></span
            >
            <span class="result-value">-</span>
          </div>

          <div class="result-divider"></div>

          <div class="result-item result-total" id="resultTotal">
            <span class="result-label">Total</span>
            <span class="result-value">Rp 0</span>
          </div>

          <div class="result-delivery" id="resultDelivery">
            <span class="delivery-icon">🚚</span>
            <span class="delivery-text"
              >Pilih tanggal untuk estimasi pengantaran</span
            >
          </div>
        </div>

        <button
          type="button"
          class="btn btn-whatsapp btn-lg"
          id="whatsappButton"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
            ></path>
          </svg>
          Pesan via WhatsApp
        </button>

        <p
          class="whatsapp-fallback"
          id="whatsappFallback"
          style="display: none;"
        >
          Atau hubungi langsung:
          <button
            type="button"
            class="copy-number"
            id="copyNumber"
            data-number={config.whatsappDisplay}
          >
            {config.whatsappDisplay} (klik untuk copy)
          </button>
        </p>
      </div>
    </div>

    <ProductModal />

    <script>
      import { initCalculator } from "@/scripts/calculator";
      initCalculator();
    </script>

    <style>
      .calculator {
        background: linear-gradient(
          to bottom,
          var(--color-primary-light) 0%,
          var(--color-background) 15%,
          var(--color-background) 100%
        );
        padding-top: var(--space-8);
        border-radius: 24px 24px 0 0;
      }

      .calculator-wrapper {
        display: grid;
        gap: var(--space-8); /* Restored from 6 */
        max-width: 900px; /* Kept same */
        margin: 0 auto;
        overflow: hidden;
        min-width: 0;
      }

      /* Ensure all form-groups respect container width */
      .calculator-wrapper > .form-group {
        max-width: 100%;
        min-width: 0;
        overflow: hidden;
      }

      .calculator-form {
        background: var(--color-surface);
        padding: var(--space-6); /* Restored from 5 */
        border-radius: var(--radius-lg);
      }

      /* Form Sections */
      .form-section {
        padding: var(--space-4) 0; /* Restored from 3 */
        border-bottom: 1px solid var(--color-border);
      }

      .form-section:last-of-type {
        border-bottom: none;
        padding-bottom: 0;
      }

      .form-section:first-of-type {
        padding-top: 0;
      }

      .form-section-header {
        display: flex;
        align-items: center;
        gap: var(--space-2); /* Kept small horizontal gap */
        margin-bottom: var(--space-4); /* Restored from 3 */
      }

      .form-section-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        background: var(--color-primary);
        color: var(--color-text-inverse);
        border-radius: 50%;
        font-size: var(--font-size-xs);
        font-weight: var(--font-weight-semibold);
        flex-shrink: 0;
      }

      .form-section-title {
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-semibold);
        color: var(--color-text);
      }

      /* Accordion */
      .accordion-item {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        margin-bottom: var(--space-4); /* Restored from 3 */
        overflow: hidden;
      }

      .accordion-header {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-3); /* Reduced from 4 */
        background: var(--color-background);
        border: none;
        cursor: pointer;
        text-align: left;
        transition: background-color var(--transition-fast);
      }

      .accordion-header:hover {
        background-color: var(--color-surface);
      }

      .accordion-item.active .accordion-header {
        background-color: var(--color-surface-elevated);
        border-bottom: 1px solid var(--color-border);
      }

      .accordion-title {
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-sm); /* Explicitly set smaller */
        color: var(--color-text);
      }

      /* Specific colors for categories */
      .accordion-item:nth-of-type(1) .accordion-title {
        color: var(--color-primary);
      }

      .accordion-item:nth-of-type(2) .accordion-title {
        color: var(--color-text-secondary);
      }

      .accordion-item:nth-of-type(3) .accordion-title {
        color: var(--color-accent);
      }

      .accordion-icon {
        font-size: var(--font-size-lg); /* Reduced from xl */
        color: var(--color-text-muted);
        line-height: 1;
      }

      .accordion-content {
        background: var(--color-surface);
        padding: var(--space-3); /* Reduced from 4 */
        border-top: 1px solid var(--color-border);
      }

      /* Override mattress-cart margin inside accordion */
      .accordion-content .mattress-cart {
        gap: var(--space-2); /* Reduced from 3 */
      }

      /* Payment Method Toggle */
      .payment-toggle {
        display: flex;
        gap: var(--space-2);
        background: var(--color-background);
        padding: var(--space-1);
        border-radius: var(--radius-md); /* Reduced from lg */
        border: 2px solid var(--color-border);
      }

      .payment-option {
        flex: 1;
        display: flex;
        flex-direction: row; /* Horizontal layout for compactness? logic check: USER asked for smaller, horizontal usually saves vertical space but icons might need column. Keep column but reduce padding */
        flex-direction: column;
        align-items: center;
        gap: 2px; /* Reduced from space-1 */
        padding: var(--space-2); /* Reduced from space-3 space-4 */
        background: transparent;
        border: none;
        border-radius: var(--radius-sm); /* Reduced from md */
        cursor: pointer;
        transition: all var(--transition-fast);
        min-height: 48px; /* Reduced touch target visual */
      }

      .payment-option:hover {
        background: var(--color-border-light);
      }

      .payment-option.active {
        background: var(--color-primary);
        color: var(--color-text-inverse);
      }

      .payment-icon {
        font-size: var(--font-size-lg); /* Reduced from xl */
      }

      .payment-label {
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-sm); /* Reduced from base */
      }

      .payment-desc {
        font-size: var(--font-size-xs);
        opacity: 0.8;
        display: none; /* Hide desc on very compact view? Or just small. Let's keep but very small or maybe hide to really declutter. */
        /* Let's keep it visible but maybe smaller. Actually display:none might be too aggressive. */
        margin-top: -2px;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3); /* Reduced from 4 */
      }

      .form-row-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3); /* Reduced from 4 */
      }

      .form-row-2 .form-group {
        margin-bottom: 0;
      }

      .form-group-small {
        max-width: 150px;
      }

      .form-input-readonly {
        background: var(--color-surface);
        color: var(--color-text-muted);
        cursor: not-allowed;
      }

      /* Mattress Cart */
      .mattress-cart {
        display: flex;
        flex-direction: column;
        gap: var(--space-2); /* Reduced from 3 */
      }

      .cart-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-2) var(--space-3); /* Significantly reduced from space-4 */
        background: var(--color-background);
        border: 1px solid var(--color-border); /* Thinner border 2px -> 1px */
        border-radius: var(--radius-md);
        transition: all var(--transition-fast);
      }

      .cart-item.is-selected {
        background-color: var(--color-secondary-light);
        border-color: var(--color-secondary);
      }

      .cart-item.highlight-pulse {
        animation: highlightPulse 2s ease infinite;
        position: relative;
        z-index: 10;
      }

      @keyframes highlightPulse {
        0% {
          box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb, 37, 99, 235), 0.4);
        }
        70% {
          box-shadow: 0 0 0 15px rgba(var(--color-primary-rgb, 37, 99, 235), 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb, 37, 99, 235), 0);
        }
      }

      .cart-item.is-large-size {
        display: none;
      }

      .cart-item.is-large-size.is-visible {
        display: flex;
      }

      .btn-show-more {
        width: 100%;
        padding: var(--space-2);
        margin-top: var(--space-2);
        background: var(--color-surface);
        border: 1px dashed var(--color-border);
        border-radius: var(--radius-md);
        color: var(--color-primary);
        font-size: var(--font-size-xs);
        font-weight: var(--font-weight-medium);
        cursor: pointer;
        transition: all var(--transition-fast);
      }

      .btn-show-more:hover {
        background: var(--color-primary-light);
        border-style: solid;
      }

      .btn-show-more.active {
        background: var(--color-primary-light);
        color: var(--color-text-secondary);
        border-style: solid;
      }

      .cart-item-thumb {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-sm);
        object-fit: cover;
        flex-shrink: 0;
        cursor: pointer;
        transition: transform var(--transition-fast);
      }

      .cart-item-thumb:hover {
        transform: scale(1.1);
      }

      .cart-item-info {
        display: flex;
        flex-direction: column;
        gap: 0; /* Reduced from space-1 */
        flex: 1;
      }

      .cart-item-name {
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-sm); /* Reduced from base */
      }

      .cart-item-dimensions {
        color: var(--color-text-muted);
        font-size: var(--font-size-xs);
      }

      .cart-item-price {
        color: var(--color-text-secondary);
        font-size: var(--font-size-xs); /* Reduced from sm */
        margin-top: 2px;
      }

      .cart-item-controls {
        display: flex;
        align-items: center;
        gap: var(--space-2); /* Reduced from 3 */
      }

      .btn-stepper {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px; /* Reduced from touch-target-min (which was 44, way too big for steppers inside cart) */
        height: 28px;
        background: var(--color-primary-light);
        border: 1px solid var(--color-primary); /* Thinner border */
        border-radius: var(--radius-sm); /* Reduced radius */
        font-size: var(--font-size-lg); /* Reduced from xl */
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        cursor: pointer;
        transition: all var(--transition-fast);
        padding: 0;
      }

      .btn-stepper:hover {
        background: var(--color-primary);
        color: var(--color-text-inverse);
      }

      .btn-stepper:disabled {
        opacity: 0.3;
        cursor: not-allowed;
      }

      .cart-item-qty {
        min-width: 24px; /* Reduced from 32 */
        text-align: center;
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-base); /* Reduced from lg */
      }

      .cart-total {
        display: flex;
        justify-content: space-between;
        padding: var(--space-2) var(--space-3); /* Reduced from 3 4 */
        margin-top: var(--space-2);
        background: var(--color-primary-light);
        border-radius: var(--radius-md);
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-sm); /* Added font size */
      }

      .cart-total-label {
        color: var(--color-text-secondary);
      }

      .cart-total-value {
        color: var(--color-primary);
      }

      /* Result Panel */
      .calculator-result {
        background: var(--color-surface-elevated);
        padding: var(--space-5); /* Reduced from 6 */
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        position: sticky;
        top: var(--space-4);
      }

      .result-summary {
        margin-bottom: var(--space-4); /* Reduced from 6 */
      }

      .result-title {
        font-size: var(--font-size-base); /* Reduced from lg */
        margin-bottom: var(--space-3); /* Reduced from 4 */
      }

      .result-item {
        display: flex;
        justify-content: space-between;
        padding: var(--space-1) 0; /* Reduced from 2 */
        font-size: var(--font-size-sm); /* Added base size */
      }

      .result-label {
        color: var(--color-text-secondary);
      }

      .result-value {
        font-weight: var(--font-weight-medium);
      }

      .result-divider {
        height: 1px;
        background: var(--color-border);
        margin: var(--space-4) 0;
      }

      .result-total {
        font-size: var(--font-size-lg);
      }

      .result-total .result-value {
        color: var(--color-primary);
        font-weight: var(--font-weight-bold);
        font-size: var(--font-size-xl);
      }

      .result-delivery {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3);
        background: var(--color-secondary-light);
        border-radius: var(--radius-md);
        margin-top: var(--space-4);
        font-size: var(--font-size-sm);
      }

      .delivery-icon {
        font-size: var(--font-size-lg);
      }

      .delivery-text {
        color: var(--color-text-secondary);
      }

      #whatsappButton {
        width: 100%;
      }

      #whatsappButton:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .address-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin-top: var(--space-2);
      }

      .whatsapp-fallback {
        text-align: center;
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        margin-top: var(--space-4);
        margin-bottom: 0;
      }

      .copy-number {
        color: var(--color-primary);
        font-weight: var(--font-weight-medium);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
      }

      .copy-number:hover {
        text-decoration: underline;
      }

      /* Location Button */
      .btn-location {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        margin-top: var(--space-2);
        padding: var(--space-2) var(--space-3);
        font-size: var(--font-size-sm);
        color: var(--color-primary);
        background: var(--color-primary-light);
        border: 1px solid var(--color-primary);
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: all var(--transition-fast);
      }

      .btn-location:hover {
        background: var(--color-primary);
        color: var(--color-text-inverse);
      }

      .btn-location:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      @media (min-width: 768px) {
        .calculator-wrapper {
          max-width: 600px;
        }

        .mattress-options {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      /* Success Message UI */
      .success-message-ui {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: var(--space-8) var(--space-4);
        background: var(--color-surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
      }

      .success-icon {
        font-size: 64px;
        margin-bottom: var(--space-4);
      }

      .success-message-ui h3 {
        color: var(--color-success);
        margin-bottom: var(--space-4);
        font-size: var(--font-size-xl);
      }

      .success-message-ui p {
        margin-bottom: var(--space-3);
        color: var(--color-text-secondary);
        line-height: 1.6;
      }

      .success-actions {
        margin-top: var(--space-6);
      }

      /* Loading Spinner */
      .loading-spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top-color: #fff;
        animation: spin 1s ease-in-out infinite;
        vertical-align: middle;
        margin-right: var(--space-2);
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .anim-fade-in {
        animation: fadeIn 0.5s ease-out forwards;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .success-btn {
        background: var(--color-success) !important;
        border-color: var(--color-success) !important;
      }
    </style>
  </div>
</section>
