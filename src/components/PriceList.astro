---
import PriceCard from "./PriceCard.astro";
import products from "@/data/products.json";
const { mattressPackages } = products;
---

<section class="price-list section" id="harga">
  <div class="container">
    <div class="category-section">
      <h2 class="section-title">Paket Kasur Lengkap</h2>
      <p class="section-subtitle">
        Sudah termasuk Kasur + Sprei + Bantal + Selimut
      </p>
      <div class="price-grid">
        {
          products.mattressPackages.map((product) => (
            <PriceCard product={product} />
          ))
        }
      </div>
    </div>

    <div class="category-section">
      <h2 class="section-title">Kasur Saja</h2>
      <p class="section-subtitle">Hanya kasur (Tanpa sprei/bantal/selimut)</p>
      <div class="price-grid">
        {
          products.mattressOnly.map((product) => (
            <PriceCard product={product} />
          ))
        }
      </div>
    </div>

    <div class="category-section">
      <h2 class="section-title">Ekstra Tambahan Satuan</h2>
      <p class="section-subtitle">
        Pilihan tambahan untuk melengkapi kenyamanan Anda
      </p>
      <div class="price-grid">
        {products.accessories.map((product) => <PriceCard product={product} />)}
      </div>
    </div>
  </div>
</section>

<style>
  .price-list {
    background: var(--color-surface);
  }

  .category-section {
    margin-bottom: var(--space-12);
  }

  .category-section:last-child {
    margin-bottom: 0;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    margin-top: calc(-1 * var(--space-6));
    margin-bottom: var(--space-6);
  }

  .price-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  @media (min-width: 640px) {
    .price-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .price-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
