<section class="problem-solution section" id="mengapa">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Kenapa Harus Sewa di Santi Living?</h2>
      <p class="section-subtitle">
        Tidur nyenyak adalah hak tamu Anda, ga harus beli kasur baru buat
        mewujudkannya.
      </p>
    </div>

    <div class="comparison-container">
      <!-- Problem Card -->
      <div class="comparison-card problem">
        <div class="card-tag problem-tag">Masalah Umum</div>
        <h3 class="comparison-title">😩 Tamu nginep, kasur kurang?</h3>
        <ul class="comparison-list">
          <li>
            <span class="icon">❌</span>
            <span>Beli baru cuma buat 3 hari? Rugi & menuh-menuhin gudang.</span
            >
          </li>
          <li>
            <span class="icon">❌</span>
            <span
              >Tidur di sofa atau kasur lipat murah bikin tamu pegel-pegel.</span
            >
          </li>
          <li>
            <span class="icon">❌</span>
            <span>Pinjam tetangga? Malu & repot pas mau balikinnya.</span>
          </li>
          <li>
            <span class="icon">❌</span>
            <span>Kasur bekas? Kebersihannya bikin was-was.</span>
          </li>
        </ul>
      </div>

      <div class="vs-divider">
        <span class="vs-text">VS</span>
      </div>

      <!-- Solution Card -->
      <div class="comparison-card solution">
        <div class="card-tag solution-tag">Solusi Santi Living</div>
        <h3 class="comparison-title">✨ Sewa saja, beres semua!</h3>
        <p class="solution-intro">
          Kasur bersih ready stock, bisa antar hari ini di area Jogja.
        </p>
        <ul class="comparison-list">
          <li>
            <span class="icon">✅</span>
            <span
              ><strong>Ga perlu beli:</strong> Lebih hemat jutaan rupiah.</span
            >
          </li>
          <li>
            <span class="icon">✅</span>
            <span
              ><strong>Ga perlu simpan:</strong> Selesai pakai, kami jemput.</span
            >
          </li>
          <li>
            <span class="icon">✅</span>
            <span
              ><strong>Tamu premium:</strong> Kasur empuk standar hotel.</span
            >
          </li>
          <li>
            <span class="icon">✅</span>
            <span
              ><strong>Pasti Steril:</strong> Selalu dicuci & didisinfektan.</span
            >
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
