---
import { Image } from "astro:assets";
import type { MattressType } from "@/types";

interface Props {
  product: MattressType;
}

const { product } = Astro.props;

const formattedPrice = new Intl.NumberFormat("id-ID").format(
  product.pricePerDay,
);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp}",
);
const imagePath = `/src/assets${product.image}`;

if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/images/*.{jpeg,jpg,png,gif,webp}"`,
  );
---

<div class="price-card">
  <div class="price-card-image">
    <Image
      src={images[imagePath]()}
      alt={product.name}
      width={800}
      height={600}
    />
  </div>

  <div class="price-card-body">
    <h3 class="price-card-title">{product.name}</h3>
    <p class="price-card-description">{product.description}</p>

    <div class="price-card-details">
      <span class="price-card-dimension">{product.dimensions}</span>
      <span class="price-card-capacity">{product.capacity}</span>
    </div>

    <div class="price-card-price">
      <span class="price-card-amount">Rp {formattedPrice}</span>
      <span class="price-card-period">/hari</span>
    </div>
  </div>
</div>

<style>
  .price-card {
    background: var(--color-surface-elevated);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition:
      transform var(--transition-normal),
      box-shadow var(--transition-normal);
  }

  .price-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .price-card-image {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-surface);
  }

  .price-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .price-card-body {
    padding: var(--space-5);
  }

  .price-card-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
  }

  .price-card-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .price-card-details {
    display: flex;
    gap: var(--space-3);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .price-card-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
  }

  .price-card-amount {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .price-card-period {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
