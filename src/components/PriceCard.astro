---
import type { ProductItem } from "@/types";

interface Props {
  product: ProductItem;
}

const { product } = Astro.props;

const formattedPrice = new Intl.NumberFormat("id-ID").format(
  product.pricePerDay
);
---

<div class="price-card">
  <div class="price-card-image">
    <img
      src={product.image}
      alt={product.name}
      loading="lazy"
      width="800"
      height="600"
    />
  </div>

  <div class="price-card-body">
    <h3 class="price-card-title">{product.name}</h3>
    <p class="price-card-description">{product.description}</p>

    <div class="price-card-details">
      <span class="price-card-dimension">{product.dimensions}</span>
      <span class="price-card-capacity">{product.capacity}</span>
    </div>

    <div class="price-card-price">
      <span class="price-card-amount">Rp {formattedPrice}</span>
      <span class="price-card-period">/hari</span>
    </div>
  </div>
</div>

<style>
  .price-card {
    background: var(--color-surface-elevated);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition:
      transform var(--transition-normal),
      box-shadow var(--transition-normal);
  }

  .price-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .price-card-image {
    aspect-ratio: 1/1;
    overflow: hidden;
    background: var(--color-surface);
  }

  .price-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .price-card-body {
    padding: var(--space-3);
  }

  .price-card-title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-1);
  }

  .price-card-description {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
    display: none;
  }

  .price-card-details {
    display: flex;
    gap: var(--space-2);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .price-card-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
  }

  .price-card-amount {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .price-card-period {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }
</style>
