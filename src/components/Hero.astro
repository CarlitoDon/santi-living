---
import config from "@/data/config.json";
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">Sewa Kasur Nyaman & Higienis di Jogja</h1>
      <p class="hero-tagline">
        Solusi cepat untuk kebutuhan tidur harian, mingguan, hingga bulanan.
      </p>

      <p class="hero-description">
        Kasur bersih, terawat, dan siap pakai. Antar–jemput tepat waktu.
      </p>

      <div class="hero-cta-group">
        <a href="#calculator" class="btn btn-primary btn-lg hero-cta">
          Pesan Sekarang
        </a>
        <a href="#calculator" class="btn btn-outline btn-lg hero-cta-secondary">
          Cek Ketersediaan
        </a>
      </div>

      <p class="hero-contact">
        Atau hubungi langsung:
        <a href={`https://wa.me/${config.whatsappNumber}`} class="hero-phone">
          {config.whatsappDisplay}
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(
      135deg,
      var(--color-primary-light) 0%,
      var(--color-background) 100%
    );
    padding: var(--space-10) 0 var(--space-12);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .hero-content {
    text-align: center;
    max-width: 650px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: var(--font-size-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-2);
    line-height: 1.2;
  }

  .hero-tagline {
    font-size: var(--font-size-base);
    color: var(--color-primary);
    font-weight: var(--font-weight-medium);
    margin-bottom: var(--space-4);
  }

  .hero-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .hero-cta-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .hero-cta,
  .hero-cta-secondary {
    width: 100%;
    max-width: 280px;
  }

  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
  }

  .btn-outline:hover {
    background: var(--color-primary);
    color: white;
  }

  .hero-contact {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .hero-phone {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
  }

  .hero-phone:hover {
    text-decoration: underline;
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: var(--font-size-4xl);
    }

    .hero-subtitle {
      font-size: var(--font-size-lg);
    }

    .hero-cta-group {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>
