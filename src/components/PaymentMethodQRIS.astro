---
import CopyButton from "./CopyButton.astro";
import config from "@/data/config.json";

interface Props {
  amount: number;
  class?: string;
}

const { amount, class: className = "" } = Astro.props;
const { qris } = config.payment;

const formatCurrency = (value: number) => {
  return new Intl.NumberFormat("id-ID").format(value);
};
---

<div class={`payment-method-card payment-qris ${className}`}>
  <div class="payment-header">
    <span class="payment-icon">📱</span>
    <h4 class="payment-title">QRIS</h4>
  </div>

  <div class="payment-details">
    <div class="qris-image-container">
      <img
        src={qris.imagePath}
        alt={`QRIS ${qris.merchantName}`}
        class="qris-image"
        loading="lazy"
      />
      <p class="merchant-name">{qris.merchantName}</p>
    </div>

    <div class="detail-row with-copy amount-row">
      <div class="detail-info">
        <span class="detail-label">Jumlah Bayar</span>
        <span class="detail-value amount">Rp {formatCurrency(amount)}</span>
      </div>
      <CopyButton value={amount.toString()} label="Copy" />
    </div>

    <a
      href={qris.imagePath}
      download="QRIS-SantiLiving.jpg"
      class="btn-download-qris"
    >
      📥 Download QRIS
    </a>
  </div>

  <div class="payment-note">
    <p>💡 Scan QRIS dengan aplikasi e-wallet atau mobile banking Anda.</p>
    <p>
      ⚠️ QRIS ini adalah QRIS statis. Pastikan input nominal sesuai total di
      atas.
    </p>
  </div>
</div>

<style>
  .payment-method-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    border: 2px solid var(--color-primary);
  }

  .payment-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .payment-icon {
    font-size: var(--font-size-xl);
  }

  .payment-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin: 0;
  }

  .payment-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
  }

  .qris-image-container {
    text-align: center;
    background: white;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .qris-image {
    max-width: 250px;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }

  .merchant-name {
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .detail-row.with-copy {
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--color-background);
    border-radius: var(--radius-md);
  }

  .detail-info {
    flex: 1;
    min-width: 0;
  }

  .detail-label {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }

  .detail-value.amount {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .amount-row {
    border: 2px solid var(--color-primary-light);
    background: var(--color-primary-light);
  }

  .btn-download-qris {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-3);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    transition: all 0.2s ease;
    min-height: 44px;
  }

  .btn-download-qris:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .payment-note {
    margin-top: var(--space-4);
    padding: var(--space-3);
    background: var(--color-info-light, #dbeafe);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    color: var(--color-info-dark, #1e40af);
  }

  .payment-note p {
    margin: 0 0 var(--space-1) 0;
  }

  .payment-note p:last-child {
    margin-bottom: 0;
  }
</style>
