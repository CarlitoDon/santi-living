---
// HowToRent - 3 steps to rent
const steps = [
  {
    number: "1",
    icon: "🛏️",
    title: "Pilih Kasur",
    description: "Pilih jenis kasur dan hitung biaya sewa dengan kalkulator",
  },
  {
    number: "2",
    icon: "💬",
    title: "Konfirmasi via WA",
    description: "Klik tombol WhatsApp, pesan otomatis terisi. Tinggal kirim!",
  },
  {
    number: "3",
    icon: "🚚",
    title: "Kasur Diantar",
    description: "Kasur bersih diantar ke alamat. Jemput saat selesai.",
  },
];
---

<section class="how-to-rent section" id="cara-sewa">
  <div class="container">
    <h2 class="section-title">Cara Sewa</h2>

    <div class="steps-grid">
      {
        steps.map((step) => (
          <div class="step-card">
            <div class="step-icon">{step.icon}</div>
            <div class="step-number">{step.number}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        ))
      }
    </div>

    <div class="how-to-cta">
      <a href="#calculator" class="btn btn-primary btn-lg">
        Mulai Sewa Sekarang
      </a>
    </div>
  </div>
</section>

<style>
  .how-to-rent {
    background: var(--color-background);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .step-card {
    position: relative;
    text-align: center;
    padding: var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
  }

  .step-icon {
    font-size: 3rem;
    margin-bottom: var(--space-3);
  }

  .step-number {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--color-text-inverse);
    border-radius: var(--radius-full);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-sm);
  }

  .step-title {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-2);
  }

  .step-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  .how-to-cta {
    text-align: center;
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
