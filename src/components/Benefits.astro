<section class="benefits section" id="benefits">
  <div class="container">
    <h2 class="section-title">Kenapa sewa kasur di tempat kami?</h2>

    <div class="benefits-grid">
      <div class="benefit-card">
        <span class="benefit-icon">🧼</span>
        <h3 class="benefit-title">Higienis & Aman</h3>
        <p class="benefit-description">
          Kasur dibersihkan dan disterilkan setiap selesai pemakaian.
        </p>
      </div>

      <div class="benefit-card">
        <span class="benefit-icon">😴</span>
        <h3 class="benefit-title">Nyaman Dipakai</h3>
        <p class="benefit-description">
          Kasur empuk, tidak kempes, layak pakai. Bukan kasur asal.
        </p>
      </div>

      <div class="benefit-card">
        <span class="benefit-icon">📅</span>
        <h3 class="benefit-title">Fleksibel Durasi</h3>
        <p class="benefit-description">
          Harian, mingguan, bulanan. Bisa perpanjang kapan saja.
        </p>
      </div>

      <div class="benefit-card">
        <span class="benefit-icon">🚚</span>
        <h3 class="benefit-title">Antar Jemput</h3>
        <p class="benefit-description">
          Kami kirim langsung ke lokasi Anda di area Jogja dan sekitarnya.
        </p>
      </div>

      <div class="benefit-card">
        <span class="benefit-icon">💰</span>
        <h3 class="benefit-title">Harga Jelas</h3>
        <p class="benefit-description">Tanpa biaya tersembunyi. Tanpa ribet.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .benefits {
    background: var(--color-background);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .benefit-card {
    background: var(--color-surface);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    text-align: center;
    border: 1px solid var(--color-border);
  }

  .benefit-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--space-3);
  }

  .benefit-title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-2);
  }

  .benefit-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (min-width: 640px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .benefits-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }
</style>
