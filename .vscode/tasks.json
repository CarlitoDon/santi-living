      "group": "test"
    },
    {
      "label": "TypeScript: Watch (Web)",
      "type": "shell",
      "command": "npx",
      "args": ["astro", "check", "--watch"],
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "problemMatcher": "$tsc-watch",
      "presentation": {
        "group": "build",
        "panel": "dedicated"
      },
      "isBackground": true
    }
  ]
