{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript: Watch",
      "type": "shell",
      "command": "./node_modules/.bin/tsc",
      "args": ["--watch", "--noEmit"],
      "problemMatcher": "$tsc-watch",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "group": "build",
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "Dev: Start All",
      "dependsOn": ["Dev: Astro", "Dev: Bot Service", "Dev: ERP Sync Service"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Dev: Astro",
      "type": "npm",
      "script": "dev",
      "problemMatcher": [],
      "presentation": {
        "group": "frontend",
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "Dev: Bot Service",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/bot-service"
      },
      "problemMatcher": [],
      "presentation": {
        "group": "backend",
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "Dev: ERP Sync Service",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/erp-sync-service"
      },
      "problemMatcher": [],
      "presentation": {
        "group": "backend",
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "Frontend: Build",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
