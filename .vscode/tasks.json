      },
      "presentation": {
        "group": "dev",
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "Turbo: Dev Web",
      "type": "npm",
      "script": "dev:web",
      "problemMatcher": [],
      "presentation": {
        "group": "frontend",
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "Turbo: Dev Proxy",
      "type": "npm",
      "script": "dev:proxy",
      "problemMatcher": [],
      "presentation": {
        "group": "backend",
        "panel": "dedicated"
      },
      "isBackground": true
    },
    {
      "label": "Turbo: Build All",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Turbo: Build Web",
      "type": "npm",
      "script": "build:web",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Turbo: Lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": ["$eslint-stylish"],
      "group": "test"
    },
    {
      "label": "Turbo: Typecheck",
      "type": "npm",
      "script": "typecheck",
